// firestore.rules
// Copy this file to your project root and deploy with:
//   firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ── Users ────────────────────────────────────────────
    // Users can read and write their own doc.
    // Admin can read all user docs.
    // Public fields readable by anyone (for team page).
    match /users/{uid} {
      // Anyone can read public profiles (for /team page)
      allow read: if resource.data.public_profile == true
                  || isOwner(uid)
                  || isAdmin();
      allow write: if isOwner(uid) || isAdmin();

      // ── Checklist state (per-user) ──────────────────
      match /checklist/{itemId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // ── Checklist items (admin-configured) ──────────────
    match /checklist_items/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Projects ─────────────────────────────────────────
    // Members can read projects they're assigned to.
    // Admin can read/write all.
    match /projects/{id} {
      allow read: if isSignedIn() &&
        (isAdmin() ||
         resource.data.lead_uid == request.auth.uid ||
         request.auth.uid in resource.data.members);
      allow write: if isAdmin();
    }

    // ── Research ideas tracker ───────────────────────────
    match /research_ideas/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Paper templates ──────────────────────────────────
    match /paper_templates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Grants (admin-only) ──────────────────────────────
    match /grants/{id} {
      allow read, write: if isAdmin();
    }
  }
}

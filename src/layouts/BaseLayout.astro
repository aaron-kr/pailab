---
// src/layouts/BaseLayout.astro
// Changes from previous version:
// • Imports + renders <TranslationBanner /> for ?notranslated=1 redirects
// • Waves animation: early head script adds html.waves-off (default OFF),
//   body script wires up .wave-btn toggles, waves.js loaded via Vite
// • <main> has no container — pages manage their own width

import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import TranslationBanner from "@/components/TranslationBanner.astro";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "ko";
  ogImage?: string;
  /** Set true on private content pages: body is hidden until Nav confirms Firebase auth */
  privatePage?: boolean;
  /** Override og:type — defaults to "website"; set "article" for blog/note pages */
  ogType?: "website" | "article";
}

const {
  title = "PAI LAB — Physical AI Laboratory",
  description = "Research lab focused on embedded systems, robotics, and real-time AI at the edge. Based in Jeonju, Korea.",
  lang = "en",
  ogImage = "/og-default.png",
  privatePage = false,
  ogType = "website",
} = Astro.props;

const siteName  = lang === "ko" ? "피지컬 AI 연구소" : "PAI LAB";
const fullTitle = title.includes("PAI LAB") ? title : `${title} · ${siteName}`;

// JSON-LD: Organization for all pages; rendered inline in <head>
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Physical AI Laboratory (PAI LAB)",
  "url": "https://pailab.io",
  "logo": "https://pailab.io/img/logo2.png",
  "sameAs": [
    "https://github.com/aaron-kr/pailab",
    "https://kspai.org",
    "https://aaron.kr"
  ],
  "founder": {
    "@type": "Person",
    "name": "Aaron Snowberger",
    "url": "https://aaronsnowberger.com",
    "jobTitle": "Principal Investigator",
    "affiliation": {
      "@type": "Organization",
      "name": "Physical AI Laboratory"
    }
  },
  "description": "Research group based in Jeonju, Korea, working at the intersection of machine learning, embedded hardware, and physical systems."
};
---

<!doctype html>
<html lang={lang} data-theme="dark" data-lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />

  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(ogImage, Astro.site).href} />
  <meta property="og:url"         content={Astro.url.href} />
  <meta property="og:type"        content={ogType} />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:locale"      content={lang === "ko" ? "ko_KR" : "en_US"} />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(ogImage, Astro.site).href} />

  <link rel="canonical" href={Astro.url.href} />
  {lang === "en" && <link rel="alternate" hreflang="ko" href={new URL(`/ko${Astro.url.pathname}`, Astro.site).href} />}
  {lang === "ko" && <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^(\/ko)+/, "") || "/", Astro.site).href} />}
  <link rel="alternate" hreflang="x-default" href={new URL(lang === "ko" ? (Astro.url.pathname.replace(/^(\/ko)+/, "") || "/") : Astro.url.pathname, Astro.site).href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oxanium:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <title>{fullTitle}</title>

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="PAI LAB Notes (EN)" href="/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title="PAI LAB Notes (한국어)" href="/ko/rss.xml" />

  <!-- Robots: index public pages, block private pages via ProtectedLayout -->
  {!privatePage && <meta name="robots" content="index, follow" />}

  <!-- JSON-LD: Organization (all public pages) -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

  <!-- Named slot for page-specific head content (e.g. article JSON-LD) -->
  <slot name="head" />

  <!-- Apply saved theme + waves state before first paint (prevents flash) -->
  <script is:inline>
    (function () {
      const saved = localStorage.getItem("pailab-theme");
      document.documentElement.setAttribute("data-theme", saved || "dark");
      if (localStorage.getItem("pailab-waves") !== "on") {
        document.documentElement.classList.add("waves-off");
      }
    })();
  </script>
</head>

<body
  data-private-page={privatePage ? "true" : undefined}
  style={privatePage ? "visibility:hidden" : undefined}
>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Nav lang={lang} currentPath={Astro.url.pathname} />
  <TranslationBanner />

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer full-bleed" data-pagefind-ignore>
    <div class="container">
      <Footer lang={lang} />
    </div>
  </footer>

  <script>
    import "@/scripts/waves.js";

    // ── Theme toggle ──────────────────────────────────────────
    const btn = document.getElementById("theme-toggle");
    if (btn) {
      const update = (t: string) => {
        document.documentElement.setAttribute("data-theme", t);
        localStorage.setItem("pailab-theme", t);
        btn.textContent = t === "dark" ? "☀" : "☾";
      };
      update(document.documentElement.getAttribute("data-theme") ?? "dark");
      btn.addEventListener("click", () => {
        update(document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark");
      });
    }

    // ── Waves toggle ──────────────────────────────────────────
    const applyWaves = (on: boolean) => {
      document.documentElement.classList.toggle("waves-off", !on);
      document.querySelectorAll<HTMLButtonElement>(".wave-btn").forEach(b => {
        b.textContent = on ? "🌊" : "〰";
      });
      localStorage.setItem("pailab-waves", on ? "on" : "off");
    };
    applyWaves(localStorage.getItem("pailab-waves") === "on");
    document.querySelectorAll(".wave-btn").forEach(b =>
      b.addEventListener("click", () =>
        applyWaves(document.documentElement.classList.contains("waves-off"))
      )
    );
  </script>
</body>
</html>

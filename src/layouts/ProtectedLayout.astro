---
// src/layouts/ProtectedLayout.astro
// App shell for /admin and /members pages.
// Uses the exact same login-page dark mesh + grid aesthetic so the whole
// authenticated area feels like one cohesive dark-mode experience.
//
// Sidebar nav items are passed via the `navItems` prop or you can
// override the entire sidebar with the "sidebar" slot.

import "@/styles/global.css";

interface NavItem {
  href: string;
  label: string;
  icon?: string;
}

interface Props {
  title: string;
  description?: string;
  activeHref?: string;
  area?: "admin" | "members"; // controls which nav links show
}

const { title, description, activeHref, area = "members" } = Astro.props;

const adminNav: NavItem[] = [
  { href: "/admin",           label: "Dashboard",   icon: "◈" },
  { href: "/admin/tracker",   label: "Tracker",     icon: "⊞" },
  { href: "/admin/students",  label: "Students",    icon: "◉" },
  { href: "/admin/content",   label: "Content",     icon: "≡" },
  { href: "/admin/settings",  label: "Settings",    icon: "⚙" },
];

const membersNav: NavItem[] = [
  { href: "/members",          label: "Dashboard",   icon: "◈" },
  { href: "/members/projects", label: "Projects",    icon: "⊞" },
  { href: "/members/notes",    label: "Notes",       icon: "≡" },
  { href: "/members/profile",  label: "Profile",     icon: "◉" },
];

const navItems = area === "admin" ? adminNav : membersNav;
const siteLabel = area === "admin" ? "ADMIN" : "MEMBERS";
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · PAI LAB</title>
  {description && <meta name="description" content={description} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oxanium:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Always dark in protected area — no flash -->
  <script is:inline>document.documentElement.setAttribute("data-theme","dark");</script>
</head>

<body class="app-body">

  <!-- ── Background layer (fixed, behind everything) ───── -->
  <div class="app-mesh-bg" aria-hidden="true"></div>
  <div class="app-mesh-grid" aria-hidden="true"></div>

  <!-- ── App shell ─────────────────────────────────────── -->
  <div class="app-shell">

    <!-- Sidebar -->
    <aside class="app-sidebar">
      <div class="app-sidebar-top">
        <a href="/" class="app-logo">
          <span class="app-logo-wordmark">PAI</span>
          <span class="app-logo-area">{siteLabel}</span>
        </a>
      </div>

      <nav class="app-nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={["app-nav-link", { active: activeHref === item.href }]}
          >
            {item.icon && <span class="app-nav-icon">{item.icon}</span>}
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <div class="app-sidebar-bottom">
        <a href="/" class="app-nav-link">
          <span class="app-nav-icon">←</span>
          <span>Public site</span>
        </a>
        <button id="app-logout" class="app-nav-link app-logout">
          <span class="app-nav-icon">⏻</span>
          <span>Sign out</span>
        </button>
      </div>
    </aside>

    <!-- Main content area -->
    <div class="app-main-wrap">
      <!-- Top bar -->
      <header class="app-topbar">
        <div class="app-topbar-title">
          <h1>{title}</h1>
          {description && <p class="app-topbar-desc">{description}</p>}
        </div>
        <div class="app-topbar-actions">
          <slot name="topbar-actions" />
          <div id="app-user-badge" class="app-user-badge">
            <span class="app-user-avatar">AS</span>
          </div>
        </div>
      </header>

      <!-- Page content -->
      <main class="app-main">
        <slot />
      </main>
    </div>

  </div>

  <script>
    import { getAuth, signOut, onAuthStateChanged } from "firebase/auth";
    import { app } from "@/lib/firebase";

    const auth = getAuth(app);

    // Guard: redirect to login if not authenticated
    onAuthStateChanged(auth, (user) => {
      if (!user) {
        window.location.href = "/login";
        return;
      }
      // Update avatar with user initials
      const badge = document.getElementById("app-user-badge");
      if (badge && user.displayName) {
        const initials = user.displayName.split(" ").map(n => n[0]).join("").slice(0,2).toUpperCase();
        badge.querySelector(".app-user-avatar")!.textContent = initials;
      }
      if (badge && user.email) {
        badge.setAttribute("title", user.email);
      }
    });

    // Logout
    document.getElementById("app-logout")?.addEventListener("click", async () => {
      await signOut(auth);
      window.location.href = "/login";
    });
  </script>

</body>
</html>

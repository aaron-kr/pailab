---
// src/layouts/ProtectedLayout.astro
// ── WHY FIRESTORE WASN'T LOADING & SIGN-OUT DIDN'T WORK ──
//
// Root cause #1: `<script src="../scripts/protected.ts">` treated as static asset.
//   → TypeScript not compiled, Firebase never initialized. (Fixed in last patch.)
//
// Root cause #2 (this patch): `import { app } from "@/lib/firebase"` inside
//   a layout's <script> block resolves differently than in page <script> blocks.
//   The layout and page scripts bundle SEPARATELY, so "@/lib/firebase" could
//   produce two separate Firebase app instances, causing "app already exists" 
//   errors OR the getAuth()/getFirestore() in page scripts to see no initialized app.
//
// Fix: Initialize Firebase ONCE in ProtectedLayout using the getApps() guard.
//   Page-level scripts (tracker, grants, etc.) then call getAuth()/getFirestore()
//   WITHOUT passing an `app` argument — they use the already-initialized default app.
//   This is the Firebase SDK's intended pattern for multi-module apps.
// ────────────────────────────────────────────────────────────────────────────────

import "@/styles/global.css";

interface NavItem { href: string; label: string; icon: string; }
interface Props {
  title: string;
  description?: string;
  activeHref?: string;
  area?: "admin" | "members" | "auto";
  requireAdmin?: boolean;
}

const { title, description, activeHref, area = "auto", requireAdmin = false } = Astro.props;

const resolvedArea = area !== "auto"
  ? area
  : Astro.url.pathname.startsWith("/admin") ? "admin" : "members";

const adminNav: NavItem[] = [
  { href: "/admin",              label: "Dashboard",    icon: "◈" },
  { href: "/admin/tracker",      label: "Tracker",      icon: "⊞" },
  { href: "/admin/members-list", label: "Members",      icon: "◉" },
  { href: "/admin/publications", label: "Publications", icon: "📄" },
  { href: "/admin/grants",       label: "Grants",       icon: "💰" },
  { href: "/admin/students",     label: "Student Mgmt", icon: "≋" },
  { href: "/admin/content",      label: "Content",      icon: "≡" },
  { href: "/admin/settings",     label: "Settings",     icon: "⚙" },
];
const membersNav: NavItem[] = [
  { href: "/members",           label: "Dashboard", icon: "◈" },
  { href: "/members/projects",  label: "Projects",  icon: "⊞" },
  { href: "/members/notes",     label: "Notes",     icon: "≡" },
  { href: "/members/profile",   label: "Profile",   icon: "◉" },
];

const navItems  = resolvedArea === "admin" ? adminNav : membersNav;
const siteLabel = resolvedArea === "admin" ? "ADMIN" : "MEMBERS";

// Pass Firebase config to client via server-rendered data attributes
// (avoids @/ alias resolution issues in bundled scripts)
const fbConfig = {
  apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY ?? "",
  authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN ?? "",
  projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID ?? "",
  storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET ?? "",
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID ?? "",
  appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID ?? "",
};
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · PAI LAB</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oxanium:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>document.documentElement.setAttribute("data-theme","dark");</script>
</head>

<body class="app-body" style="visibility:hidden" data-pagefind-ignore>
  <div class="app-mesh-bg" aria-hidden="true"></div>
  <div class="app-mesh-grid" aria-hidden="true"></div>

  <!-- Mobile overlay backdrop -->
  <div class="sidebar-backdrop" id="sidebar-backdrop" aria-hidden="true"></div>

  <div class="app-shell">
    <aside class="app-sidebar" id="app-sidebar">
      <div class="app-sidebar-top">
        <a href="/" class="app-logo" title="PAI LAB">
          <img src="/favicon.svg" alt="PAI LAB" class="members-logo-img" />
          <span class="app-logo-area">{siteLabel}</span>
        </a>
      </div>

      <nav class="app-nav">
        {navItems.map((item) => (
          <a href={item.href}
             title={item.label}
             class:list={["app-nav-link", {
               active: activeHref === item.href || Astro.url.pathname === item.href
             }]}>
            <span class="app-nav-icon">{item.icon}</span>
            <span class="app-nav-label">{item.label}</span>
          </a>
        ))}
        <div class="app-nav-divider"></div>
        {resolvedArea === "admin" ? (
          <a href="/members" class="app-nav-link app-nav-link--dim" title="Members view">
            <span class="app-nav-icon">↓</span><span class="app-nav-label">Members view</span>
          </a>
        ) : (
          <a href="/admin" class="app-nav-link app-nav-link--dim" id="admin-link" style="display:none" title="Admin view">
            <span class="app-nav-icon">↑</span><span class="app-nav-label">Admin view</span>
          </a>
        )}
      </nav>

      <div class="app-sidebar-bottom">
        <a href="/" class="app-nav-link" title="Public site">
          <span class="app-nav-icon">←</span><span class="app-nav-label">Public site</span>
        </a>
        <button id="app-logout" class="app-nav-link app-logout" type="button" title="Sign out">
          <span class="app-nav-icon">⏻</span><span class="app-nav-label">Sign out</span>
        </button>
        <!-- Desktop sidebar collapse toggle -->
        <button id="sidebar-toggle" class="app-nav-link sidebar-collapse-btn" type="button" title="Collapse sidebar">
          <span class="app-nav-icon sidebar-toggle-icon">◀</span>
          <span class="app-nav-label">Collapse</span>
        </button>
      </div>
    </aside>

    <div class="app-main-wrap">
      <header class="app-topbar">
        <div class="app-topbar-left">
          <!-- Mobile hamburger button -->
          <button id="sidebar-menu-btn" class="sidebar-menu-btn" type="button" aria-label="Toggle menu" title="Menu">
            <span>☰</span>
          </button>
          <div class="app-topbar-title">
            <h1>{title}</h1>
            {description && <p class="app-topbar-desc">{description}</p>}
          </div>
        </div>
        <div class="app-topbar-actions">
          <slot name="topbar-actions" />
          <button id="app-logout-top" class="app-logout-btn" type="button">Sign out</button>
          <div id="app-user-badge" class="app-user-badge">
            <span class="app-user-avatar" id="app-user-avatar">—</span>
          </div>
        </div>
      </header>
      <main class="app-main"><slot /></main>
    </div>
  </div>

  <!-- Config injected server-side as a JSON data attribute -->
  <script
    id="pailab-config"
    type="application/json"
    data-require-admin={requireAdmin ? "true" : "false"}
    data-resolved-area={resolvedArea}
    set:html={JSON.stringify(fbConfig)}
  ></script>

  <script>
    // ── Sidebar collapse / mobile overlay ────────────────────
    const appShell   = document.querySelector(".app-shell") as HTMLElement;
    const backdrop   = document.getElementById("sidebar-backdrop");
    const SIDEBAR_KEY = "pailab-sidebar-collapsed";

    const isMobileView = () => window.innerWidth < 900;

    // Restore desktop collapse state before the page is revealed (body still hidden)
    if (!isMobileView() && localStorage.getItem(SIDEBAR_KEY) === "true") {
      appShell?.classList.add("sidebar-collapsed");
    }

    // Desktop: collapse/expand toggle in sidebar bottom
    document.getElementById("sidebar-toggle")?.addEventListener("click", () => {
      const collapsed = appShell.classList.toggle("sidebar-collapsed");
      localStorage.setItem(SIDEBAR_KEY, collapsed ? "true" : "false");
    });

    // Mobile: open sidebar via topbar hamburger
    document.getElementById("sidebar-menu-btn")?.addEventListener("click", () => {
      appShell.classList.toggle("sidebar-open");
    });

    // Mobile: close on backdrop click
    backdrop?.addEventListener("click", () => {
      appShell.classList.remove("sidebar-open");
    });

    // Mobile: close sidebar when a nav link is clicked
    document.querySelectorAll(".app-nav-link").forEach(link => {
      link.addEventListener("click", () => {
        if (isMobileView()) appShell.classList.remove("sidebar-open");
      });
    });

    // On resize: clean up open/collapsed states when switching breakpoints
    window.addEventListener("resize", () => {
      if (isMobileView()) {
        appShell.classList.remove("sidebar-collapsed");
      } else {
        appShell.classList.remove("sidebar-open");
        // Re-apply desktop preference
        if (localStorage.getItem(SIDEBAR_KEY) === "true") {
          appShell.classList.add("sidebar-collapsed");
        }
      }
    }, { passive: true });

    // ── Firebase initialization ─────────────────────────────
    // Read config from server-injected JSON (avoids @/ alias issues in bundled scripts)
    import {
      initializeApp, getApps, getApp
    } from "firebase/app";
    import {
      getAuth, signOut, onAuthStateChanged
    } from "firebase/auth";
    import {
      getFirestore, doc, getDoc, setDoc, serverTimestamp
    } from "firebase/firestore";

    const configEl = document.getElementById("pailab-config")!;
    const fbConfig = JSON.parse(configEl.textContent || "{}");
    const requireAdmin = configEl.dataset.requireAdmin === "true";

    // Safe init: only create app if it doesn't exist yet
    const firebaseApp = getApps().length === 0
      ? initializeApp(fbConfig)
      : getApp();

    // Store on window so page-level scripts can reuse without re-initializing
    (window as any).__pailab_firebase_app = firebaseApp;

    const auth = getAuth(firebaseApp);
    const db   = getFirestore(firebaseApp);

    // ── Sign-out ──────────────────────────────────────────────
    async function doSignOut() {
      sessionStorage.removeItem("pailab-role");
      sessionStorage.removeItem("pailab-uid");
      try { await signOut(auth); } catch (e) { console.error("signOut error", e); }
      window.location.href = "/login";
    }
    document.getElementById("app-logout")?.addEventListener("click", doSignOut);
    document.getElementById("app-logout-top")?.addEventListener("click", doSignOut);

    // ── Auth guard ────────────────────────────────────────────
    onAuthStateChanged(auth, async (user) => {
      if (!user) {
        window.location.href = "/login";
        return;
      }

      // Role: session cache → Firestore
      let role = sessionStorage.getItem("pailab-role");
      if (!role || sessionStorage.getItem("pailab-uid") !== user.uid) {
        try {
          const snap = await getDoc(doc(db, "users", user.uid));
          if (snap.exists()) {
            role = snap.data().role ?? "member";
          } else {
            role = "member";
            await setDoc(doc(db, "users", user.uid), {
              displayName: user.displayName ?? "",
              email: user.email ?? "",
              photoURL: user.photoURL ?? "",
              role: "member",
              public_profile: false,
              team_order: 99,
              joined_at: serverTimestamp(),
              updated_at: serverTimestamp(),
            }, { merge: true });
          }
        } catch {
          role = "member";
        }
        sessionStorage.setItem("pailab-role", role!);
        sessionStorage.setItem("pailab-uid", user.uid);
      }

      // Guard admin pages
      if (requireAdmin && role !== "admin") {
        window.location.href = "/members";
        return;
      }

      // ✅ Auth confirmed — reveal the page
      document.body.style.visibility = "visible";

      // Show admin link for admins
      if (role === "admin") {
        const adminLink = document.getElementById("admin-link");
        if (adminLink) adminLink.style.display = "flex";
      }

      // Avatar
      const avatarEl = document.getElementById("app-user-avatar");
      if (avatarEl) {
        if (user.photoURL) {
          avatarEl.innerHTML = `<img src="${user.photoURL}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"/>`;
        } else if (user.displayName) {
          avatarEl.textContent = user.displayName.split(" ").map((n: string) => n[0]).join("").slice(0, 2).toUpperCase();
        } else {
          avatarEl.textContent = user.email?.[0]?.toUpperCase() ?? "?";
        }
      }
      const badge = document.getElementById("app-user-badge");
      if (badge && user.email) badge.setAttribute("title", user.email);

      // Signal to page scripts that auth + Firebase are ready
      document.dispatchEvent(new CustomEvent("pailab:auth-ready", { detail: { user, role, db, auth } }));
    });
  </script>

</body>
</html>

<style>
.members-logo-img { height:32px; width:auto; display:block; filter:brightness(0) invert(1) drop-shadow(0 0 6px rgba(36,255,252,.4)); }
.app-logout-btn { background:none; border:.5px solid rgba(240,18,122,.25); border-radius:var(--r-sm); padding:.35rem .875rem; font-family:var(--font-mono); font-size:.65rem; color:rgba(240,18,122,.6); cursor:pointer; transition:background .15s,color .15s; }
.app-logout-btn:hover { background:rgba(240,18,122,.1); color:var(--pink); }
.app-nav-divider { height:.5px; background:rgba(36,180,255,.12); margin:.5rem .75rem; }
.app-nav-link--dim { opacity:.45; font-size:.68rem !important; }
.app-nav-link--dim:hover { opacity:1; }

/* ── Topbar left group ───────────────────────────────── */
.app-topbar-left { display:flex; align-items:center; gap:.75rem; }

/* ── Sidebar width transition (shared) ───────────────── */
.app-sidebar { transition: width .25s cubic-bezier(.4,0,.2,1); }

/* ── Desktop: collapse to icon-only ─────────────────── */
.sidebar-collapse-btn { cursor:pointer; }
.sidebar-toggle-icon { display:inline-block; transition:transform .25s cubic-bezier(.4,0,.2,1); }
.app-shell.sidebar-collapsed .sidebar-toggle-icon { transform:rotate(180deg); }

.app-shell.sidebar-collapsed .app-sidebar { width:52px; overflow:visible; }
.app-shell.sidebar-collapsed .app-logo { justify-content:center; padding:.5rem 0; }
.app-shell.sidebar-collapsed .app-logo-area { display:none; }
.app-shell.sidebar-collapsed .app-nav-link { justify-content:center; padding:.55rem; }
.app-shell.sidebar-collapsed .app-nav-label { display:none; }
.app-shell.sidebar-collapsed .app-nav-divider { margin:.5rem .25rem; }
.app-shell.sidebar-collapsed .app-sidebar-top,
.app-shell.sidebar-collapsed .app-sidebar-bottom { padding:.75rem .25rem; }

/* ── Mobile hamburger button ─────────────────────────── */
.sidebar-menu-btn {
  display:none;
  background:none; border:.5px solid rgba(36,180,255,.2);
  border-radius:var(--r-sm); width:34px; height:34px;
  cursor:pointer; color:var(--text-2); font-size:1rem;
  align-items:center; justify-content:center; flex-shrink:0;
  transition:color .15s, border-color .15s;
}
.sidebar-menu-btn:hover { color:var(--cyan); border-color:var(--cyan); }

/* ── Mobile overlay backdrop ─────────────────────────── */
.sidebar-backdrop {
  display:none;
  position:fixed; inset:0; z-index:199;
  background:rgba(2,8,20,.72);
  backdrop-filter:blur(2px);
}

/* ── Mobile breakpoint: overlay mode ────────────────── */
@media (max-width: 899px) {
  .sidebar-menu-btn { display:flex; }

  /* Sidebar slides in from left as an overlay */
  .app-sidebar {
    position:fixed; left:0; top:0; bottom:0;
    z-index:200; height:100%;
    transform:translateX(-100%);
    transition:transform .25s cubic-bezier(.4,0,.2,1);
    box-shadow:4px 0 32px rgba(0,0,8,.5);
  }
  .app-shell.sidebar-open .app-sidebar { transform:translateX(0); }
  .app-shell.sidebar-open .sidebar-backdrop { display:block; }

  /* Desktop collapse button hidden on mobile */
  .sidebar-collapse-btn { display:none; }

  /* Main content always full width on mobile */
  .app-main-wrap { width:100%; }
}
</style>

---
// src/layouts/PostLayout.astro
// Used by individual note/blog post pages.
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Lang, t } from "@/i18n/translations";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  lang: Lang;
  tags?: string[];
  naverUrl?: string;      // cross-link to Naver KR version
  altLangUrl?: string;    // link to translated version on this site
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
}

const {
  title,
  description,
  pubDate,
  lang,
  tags = [],
  naverUrl,
  altLangUrl,
  prevPost,
  nextPost,
} = Astro.props;

const dateStr   = pubDate.toISOString().slice(0, 10);
const prefix    = lang === "ko" ? "/ko" : "";
const notesPath = `${prefix}/notes`;
---

<BaseLayout lang={lang} title={`${title} · PAI LAB`} description={description}>
  <article style="padding: 1rem 0 5rem; max-width: 720px;">

    <!-- ── Breadcrumb ─────────────────────────────── -->
    <nav style="margin-bottom: 2rem; display: flex; align-items: center; gap: 8px;">
      <a href={`${prefix}/`}
         style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-3);">
        PAI LAB
      </a>
      <span style="color: var(--text-3); font-size: 0.7rem;">/</span>
      <a href={notesPath}
         style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-3);">
        {t(lang, "sec_notes")}
      </a>
    </nav>

    <!-- ── Header ────────────────────────────────── -->
    <header style="margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 0.5px solid var(--border);">
      <p style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-3); margin-bottom: 0.875rem;">
        {dateStr}
      </p>

      <h1 style="font-size: clamp(1.4rem, 3vw, 2rem); line-height: 1.25; margin-bottom: 1.25rem;">
        {title}
      </h1>

      <!-- Tags + language switcher row -->
      <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
        {tags.map((tag) => <span class="tag">{tag}</span>)}

        <!-- Cross-link to Naver Korean version -->
        {naverUrl && lang === "en" && (
          <a href={naverUrl} target="_blank" rel="noopener"
             style="font-size: 0.72rem; color: var(--text-2); border: 0.5px solid var(--border-2); border-radius: 4px; padding: 2px 8px; text-decoration: none;">
            한국어로 읽기 ↗
          </a>
        )}

        <!-- Cross-link to translated version on this site -->
        {altLangUrl && (
          <a href={altLangUrl}
             style="font-size: 0.72rem; color: var(--text-2); border: 0.5px solid var(--border-2); border-radius: 4px; padding: 2px 8px; text-decoration: none;">
            {lang === "en" ? "한국어 버전" : "English version"} →
          </a>
        )}
      </div>
    </header>

    <!-- ── Body (MDX / Markdown) ──────────────────── -->
    <div class="prose">
      <slot />
    </div>

    <!-- ── Prev / Next nav ────────────────────────── -->
    {(prevPost || nextPost) && (
      <nav style="margin-top: 4rem; padding-top: 2rem; border-top: 0.5px solid var(--border); display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          {prevPost && (
            <>
              <p style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-3); margin-bottom: 4px;">← previous</p>
              <a href={`${notesPath}/${prevPost.slug}`}
                 style="font-size: 0.85rem; font-weight: 500; color: var(--text);">
                {prevPost.title}
              </a>
            </>
          )}
        </div>
        <div style="text-align: right;">
          {nextPost && (
            <>
              <p style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-3); margin-bottom: 4px;">next →</p>
              <a href={`${notesPath}/${nextPost.slug}`}
                 style="font-size: 0.85rem; font-weight: 500; color: var(--text);">
                {nextPost.title}
              </a>
            </>
          )}
        </div>
      </nav>
    )}

    <!-- ── Back link ──────────────────────────────── -->
    <div style="margin-top: 2rem;">
      <a href={notesPath}
         style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-3);">
        ← {t(lang, "sec_notes")}
      </a>
    </div>

  </article>
</BaseLayout>

---
// src/layouts/PostLayout.astro
// Individual note/post layout with PageHeader, optional featuredImage, prev/next nav.
//
// Frontmatter in notes can now include:
//   featuredImage: "/images/my-post-hero.jpg"   ← wide image at top of post
//   headerBgImage: "/images/header-bg.jpg"        ← subtle bg in the page header strip

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { t, type Lang } from "@/i18n/translations";

interface Props {
  title: string;
  title_ko?: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  naverUrl?: string;
  lang?: Lang;
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
  featuredImage?: string;   // ← full-width image shown above post body
  headerBgImage?: string;   // ← subtle background for the page header strip
}

const {
  title,
  title_ko,
  description,
  pubDate,
  tags = [],
  naverUrl,
  lang = "en",
  prevPost,
  nextPost,
  featuredImage,
  headerBgImage,
} = Astro.props;

const notesPath = lang === "ko" ? "/ko/notes" : "/notes";
const dateStr   = pubDate.toLocaleDateString(lang === "ko" ? "ko-KR" : "en-US", {
  year: "numeric", month: "long", day: "numeric",
});
const altTitle = lang === "ko" ? title : (title_ko ?? title);
---

<BaseLayout lang={lang} title={`${title} · PAI LAB`} description={description}>

  <!-- ── Page header strip ──────────────────────────────── -->
  <PageHeader
    title={title}
    description={description}
    eyebrow={dateStr}
    bgImage={headerBgImage}
    size="sm"
  />

  <!-- ── Article wrapper ───────────────────────────────── -->
  <div class="container page-content">
    <article>

      <!-- Tags + Naver link row -->
      <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:2rem;">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
        {naverUrl && (
          <a
            href={naverUrl}
            target="_blank"
            rel="noopener"
            style="font-size:.72rem; color:var(--text-2); border:.5px solid var(--border-2); border-radius:4px; padding:2px 8px;"
          >
            {lang === "ko" ? "영어로 읽기 ↗" : "한국어로 읽기 ↗"}
          </a>
        )}
        {lang === "en" && title_ko && (
          <span style="font-size:.72rem; color:var(--text-3);">{title_ko}</span>
        )}
      </div>

      <!-- ── Featured image (optional wide photo) ───────── -->
      {featuredImage && (
        <div class="featured-image-wrap">
          <img src={featuredImage} alt={title} loading="lazy" />
        </div>
      )}

      <!-- ── Prose body ────────────────────────────────── -->
      <div class="prose">
        <slot />
      </div>

      <!-- ── Prev / Next navigation ────────────────────── -->
      {(prevPost || nextPost) && (
        <nav class="post-nav">
          <div class="post-nav-item">
            {prevPost && (
              <>
                <p class="post-nav-label">← {t(lang, "prev")}</p>
                <a href={`${notesPath}/${prevPost.slug}`} class="post-nav-link">
                  {prevPost.title}
                </a>
              </>
            )}
          </div>
          <div class="post-nav-item post-nav-item--right">
            {nextPost && (
              <>
                <p class="post-nav-label">{t(lang, "next")} →</p>
                <a href={`${notesPath}/${nextPost.slug}`} class="post-nav-link">
                  {nextPost.title}
                </a>
              </>
            )}
          </div>
        </nav>
      )}

      <!-- ── Back to notes ─────────────────────────────── -->
      <div style="margin-top:2rem;">
        <a href={notesPath} class="back-link">
          ← {t(lang, "sec_notes")}
        </a>
      </div>

    </article>
  </div>

</BaseLayout>

<style>
.post-nav {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: .5px solid var(--border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.post-nav-item--right { text-align: right; }
.post-nav-label {
  font-family: var(--font-mono);
  font-size: .65rem;
  color: var(--text-3);
  margin-bottom: 4px;
}
.post-nav-link {
  font-size: .85rem;
  font-weight: 500;
  color: var(--text);
}
.post-nav-link:hover { color: var(--cyan); text-decoration: none; }
.back-link {
  font-family: var(--font-mono);
  font-size: .72rem;
  color: var(--text-3);
}
.back-link:hover { color: var(--cyan); text-decoration: none; }
</style>

---
// src/components/PaperRow.astro
// Renders one paper row. Two visual variants:
//   variant="journal"     — full editorial row (default, more vertical space)
//   variant="conference"  — compact row (tighter padding, smaller title)
//
// Supported link fields (all optional, show only when set):
//   doi              → "DOI ↗"  (journals)
//   pdf              → "PDF ↗"  (direct PDF link)
//   researchgate_url → "PDF ↗"  (conferences — RG upload)
//   proceedings_url  → "Proc ↗" (link to conference proceedings index)
//   slides_url       → "Slides ↗" (SlideDeck or Google Slides)
//   video_url        → "Video ↗" (YouTube recording)
//
// "Cite" button generates BibTeX inline — no server needed.

import { type CollectionEntry } from "astro:content";
import type { Lang } from "@/i18n/translations";

interface Props {
  paper: CollectionEntry<"research">;
  lang?: Lang;
  variant?: "journal" | "conference";
}

const { paper, lang = "en", variant = "journal" } = Astro.props;
const {
  title, title_ko, authors, venue, year, status,
  doi, pdf, researchgate_url, proceedings_url, slides_url, video_url,
  tags, thumbnailUrl,
} = paper.data;

const displayTitle = lang === "ko" && title_ko ? title_ko : title;
const altTitle     = lang === "ko" ? title : (title_ko ?? null);

const statusLabel: Record<string, string> = {
  "published":  "published",
  "in-review":  "in review",
  "preprint":   "preprint",
};
const statusColor: Record<string, string> = {
  "published": "var(--green-glow)",
  "in-review": "var(--cyan)",
  "preprint":  "var(--blue-2)",
};

// Build BibTeX string for the Cite popup (rendered client-side)
const bibType   = variant === "journal" ? "article" : "inproceedings";
const bibField  = variant === "journal" ? "journal" : "booktitle";
const bibKey    = `snowberger${year}${title.toLowerCase().replace(/[^a-z]/g, "").slice(0, 14)}`;
const bibDoi    = doi || researchgate_url || proceedings_url || "";
const bibTex    = [
  `@${bibType}{${bibKey},`,
  `  author    = {${authors}},`,
  `  title     = {${title}},`,
  `  ${bibField.padEnd(9)} = {${venue}},`,
  `  year      = {${year}},`,
  bibDoi ? `  doi       = {${bibDoi}},` : null,
  `}`,
].filter(Boolean).join("\n");

// Unique id for this row's cite popup
const citeId = `cite-${paper.slug}`;

const isConference = variant === "conference";
---

<div
  class:list={[
    "paper-row",
    { "paper-row--has-thumb": !!thumbnailUrl && !isConference },
    { "paper-row--conference": isConference },
  ]}
  data-bibtex={bibTex}
  data-cite-id={citeId}
>

  {/* Thumbnail: journal rows only */}
  {thumbnailUrl && !isConference && (
    <div class="paper-thumb">
      <img src={thumbnailUrl} alt={displayTitle} loading="lazy" />
    </div>
  )}

  <div class="paper-content">

    {/* Top row: venue · year + status pill */}
    <div class="paper-top">
      <div class="paper-venue-year">
        <span class="paper-year">{year}</span>
        <span class="paper-sep">·</span>
        <span class="paper-venue">{venue}</span>
      </div>
      <span
        class="status-pill"
        style={`color:${statusColor[status] ?? "var(--text-3)"}; border-color:${statusColor[status] ?? "var(--border)"}`}
      >
        {statusLabel[status] ?? status}
      </span>
    </div>

    {/* Title */}
    <h3 class="paper-title">{displayTitle}</h3>
    {altTitle && <p class="paper-alt-title">{altTitle}</p>}

    {/* Authors */}
    <p class="paper-authors">{authors}</p>

    {/* Tags + links */}
    <div class="paper-footer">
      <div class="paper-tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      <div class="paper-links">
        {doi              && <a href={doi}              target="_blank" rel="noopener" class="paper-link paper-link--doi">DOI ↗</a>}
        {pdf              && <a href={pdf}              target="_blank" rel="noopener" class="paper-link">PDF ↗</a>}
        {researchgate_url && <a href={researchgate_url} target="_blank" rel="noopener" class="paper-link paper-link--rg">RG ↗</a>}
        {proceedings_url  && <a href={proceedings_url}  target="_blank" rel="noopener" class="paper-link paper-link--proc">Proc ↗</a>}
        {slides_url       && <a href={slides_url}       target="_blank" rel="noopener" class="paper-link paper-link--slides">Slides ↗</a>}
        {video_url        && <a href={video_url}        target="_blank" rel="noopener" class="paper-link paper-link--video">Video ↗</a>}
        <button class="paper-link paper-link--cite" data-cite-trigger={citeId} aria-label="Copy BibTeX citation">
          Cite
        </button>
      </div>
    </div>

  </div>
</div>

{/* BibTeX popup — hidden until Cite button clicked */}
<div class="cite-popup" id={citeId} aria-hidden="true">
  <div class="cite-popup-inner">
    <div class="cite-popup-header">
      <span class="cite-popup-label">BibTeX</span>
      <button class="cite-popup-close" data-cite-close={citeId} aria-label="Close">✕</button>
    </div>
    <pre class="cite-popup-code">{bibTex}</pre>
    <button class="cite-copy-btn" data-cite-copy={citeId}>Copy to clipboard</button>
  </div>
</div>

<style>
/* ── Row layout ──────────────────────────────────────── */
.paper-row {
  display: flex;
  gap: 1.25rem;
  padding: 1.25rem 0;
  border-top: .5px solid var(--border);
  align-items: flex-start;
  position: relative;
}
.paper-row:first-child { border-top: none; }

/* Conference rows: tighter padding */
.paper-row--conference {
  padding: .75rem 0;
}

/* ── Thumbnail (journals only) ───────────────────────── */
.paper-thumb {
  width: 68px; height: 68px;
  flex-shrink: 0;
  border-radius: var(--r-sm);
  overflow: hidden;
  background: var(--bg-subtle);
  border: .5px solid var(--border);
}
.paper-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Content ─────────────────────────────────────────── */
.paper-content { flex: 1; min-width: 0; }

.paper-top {
  display: flex; justify-content: space-between; align-items: center;
  gap: .5rem; margin-bottom: .3rem;
}
.paper-venue-year {
  display: flex; align-items: center; gap: .35rem;
  font-family: var(--font-mono); color: var(--text-3);
}
/* Journal rows: slightly larger meta */
.paper-row:not(.paper-row--conference) .paper-venue-year { font-size: .65rem; }
/* Conference rows: smaller meta */
.paper-row--conference .paper-venue-year { font-size: .6rem; }

.paper-sep { opacity: .35; }
.paper-year { font-weight: 500; }

.status-pill {
  font-family: var(--font-mono); font-size: .56rem;
  border: .5px solid; border-radius: 3px; padding: 1px 5px;
  white-space: nowrap; flex-shrink: 0;
  opacity: .85;
}

/* Journal title: more prominent */
.paper-row:not(.paper-row--conference) .paper-title {
  font-family: var(--font-display);
  font-size: .93rem; font-weight: 600; line-height: 1.4;
  margin-bottom: .25rem; color: var(--text);
}
/* Conference title: slightly smaller */
.paper-row--conference .paper-title {
  font-family: var(--font-display);
  font-size: .82rem; font-weight: 500; line-height: 1.38;
  margin-bottom: .2rem; color: var(--text);
}

.paper-alt-title {
  font-size: .72rem; color: var(--text-3); margin-bottom: .35rem; line-height: 1.4;
}
/* Conference rows: hide alt-title to save space */
.paper-row--conference .paper-alt-title {
  display: none;
}

.paper-authors {
  font-size: .7rem; color: var(--text-2); margin-bottom: .5rem;
  font-style: italic;
}
.paper-row--conference .paper-authors {
  font-size: .66rem; margin-bottom: .35rem;
}

/* ── Footer ──────────────────────────────────────────── */
.paper-footer {
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: .4rem;
}
.paper-tags { display: flex; flex-wrap: wrap; gap: 3px; }
.paper-row--conference .paper-tags { display: none; } /* hide tags on conf rows — too noisy at scale */

.paper-links { display: flex; gap: .35rem; flex-shrink: 0; flex-wrap: wrap; }

.paper-link {
  font-family: var(--font-mono); font-size: .6rem; color: var(--cyan);
  text-decoration: none; background: none;
  border: .5px solid rgba(36,180,255,.18);
  border-radius: 3px; padding: 2px 7px;
  cursor: pointer;
  transition: background .12s, color .12s, border-color .12s;
  white-space: nowrap;
}
.paper-link:hover {
  background: rgba(36,180,255,.1);
  text-decoration: none;
}
/* Color-coded link types */
.paper-link--doi    { color: var(--green);  border-color: rgba(45,212,191,.2); }
.paper-link--doi:hover { background: rgba(45,212,191,.1); }
.paper-link--rg     { color: var(--blue-2); border-color: rgba(61,146,245,.2); }
.paper-link--rg:hover { background: rgba(61,146,245,.1); }
.paper-link--slides { color: var(--cyan);   border-color: rgba(36,255,252,.2); }
.paper-link--video  { color: var(--pink-2); border-color: rgba(255,90,168,.2); }
.paper-link--video:hover { background: rgba(255,90,168,.1); }
.paper-link--cite   { color: var(--text-3); border-color: var(--border); }
.paper-link--cite:hover { color: var(--text-2); }

/* ── BibTeX popup ────────────────────────────────────── */
.cite-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 500;
  align-items: center;
  justify-content: center;
  background: rgba(2,8,20,.7);
  backdrop-filter: blur(6px);
  padding: 1.5rem;
}
.cite-popup.is-open {
  display: flex;
}
.cite-popup-inner {
  background: var(--bg-surface);
  border: .5px solid var(--border-2);
  border-radius: var(--r-lg);
  padding: 1.25rem;
  max-width: 540px;
  width: 100%;
  box-shadow: 0 0 40px rgba(0,0,0,.5);
}
.cite-popup-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: .75rem;
}
.cite-popup-label {
  font-family: var(--font-mono); font-size: .65rem;
  color: var(--cyan); letter-spacing: .1em;
}
.cite-popup-close {
  background: none; border: none; color: var(--text-3);
  font-size: .85rem; cursor: pointer; padding: 2px 6px;
  border-radius: var(--r-sm);
  transition: color .12s, background .12s;
}
.cite-popup-close:hover { color: var(--text); background: var(--bg-subtle); }
.cite-popup-code {
  background: var(--bg-subtle);
  border: .5px solid var(--border);
  border-radius: var(--r-md);
  padding: 1rem;
  font-family: var(--font-mono);
  font-size: .72rem;
  line-height: 1.65;
  color: var(--text-2);
  overflow-x: auto;
  margin-bottom: .75rem;
  white-space: pre;
}
.cite-copy-btn {
  font-family: var(--font-mono); font-size: .65rem;
  color: var(--green); background: none;
  border: .5px solid rgba(45,212,191,.25);
  border-radius: var(--r-sm); padding: 4px 12px;
  cursor: pointer;
  transition: background .12s;
}
.cite-copy-btn:hover { background: rgba(45,212,191,.1); }
</style>

<script>
// One-time event listener setup (Astro ensures this runs once per page)
(function () {
  if ((window as any).__paipopup) return;
  (window as any).__paipopup = true;

  document.addEventListener("click", (e: Event) => {
    const target = e.target as HTMLElement;

    // Open
    const triggerEl = target.closest("[data-cite-trigger]") as HTMLElement | null;
    if (triggerEl) {
      const id = triggerEl.dataset.citeTrigger!;
      document.getElementById(id)?.classList.add("is-open");
      return;
    }

    // Close button
    const closeEl = target.closest("[data-cite-close]") as HTMLElement | null;
    if (closeEl) {
      const id = closeEl.dataset.citeClose!;
      document.getElementById(id)?.classList.remove("is-open");
      return;
    }

    // Click outside popup inner
    const popupInner = target.closest(".cite-popup-inner");
    if (!popupInner) {
      document.querySelectorAll(".cite-popup.is-open").forEach(el => el.classList.remove("is-open"));
    }
  });

  // Escape key
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") {
      document.querySelectorAll(".cite-popup.is-open").forEach(el => el.classList.remove("is-open"));
    }
  });

  // Copy button
  document.addEventListener("click", async (e: Event) => {
    const btn = (e.target as HTMLElement).closest("[data-cite-copy]") as HTMLElement | null;
    if (!btn) return;
    const id   = btn.dataset.citeCopy!;
    const code = document.querySelector(`#${id} .cite-popup-code`)?.textContent ?? "";
    await navigator.clipboard.writeText(code);
    const orig = btn.textContent;
    btn.textContent = "Copied!";
    setTimeout(() => { btn.textContent = orig; }, 1800);
  });
})();
</script>

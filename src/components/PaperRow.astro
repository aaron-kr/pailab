---
// src/components/PaperRow.astro
// Editorial list-row style for papers — used on homepage + /research page.
import type { CollectionEntry } from "astro:content";
import { type Lang } from "@/i18n/translations";

interface Props {
  paper: CollectionEntry<"research">;
  lang: Lang;
}
const { paper, lang } = Astro.props;
const { title, title_ko, authors, venue, year, status, doi, pdf, tags } = paper.data;
const displayTitle = lang === "ko" && title_ko ? title_ko : title;

const pillClass = status === "published" ? "ok" : status === "in-review" ? "warn" : "blue";
const pillLabel: Record<string, Record<Lang, string>> = {
  "published": { en:"Published",  ko:"게시됨"  },
  "in-review": { en:"In review",  ko:"검토 중" },
  "preprint":  { en:"Preprint",   ko:"프리프린트" },
};
---

<div class="paper-row">
  <div>
    <span class="paper-year">{year}</span>
  </div>
  <div>
    <span class="paper-venue">{venue}</span>
    <p class="paper-title-row">
      {doi
        ? <a href={doi} target="_blank" rel="noopener">{displayTitle}</a>
        : <span>{displayTitle}</span>
      }
      {pdf && !doi && <a href={pdf} target="_blank" rel="noopener">{displayTitle}</a>}
    </p>
    <p class="paper-authors">{authors}</p>
    <div>
      {tags.map((tag) => (
        <span class={`tag${tag === "Physical AI" ? " green" : tag === "Dataset" ? " pink" : tag === "Vision" || tag === "Script OCR" || tag === "ML" || tag === "Inference" ? " blue" : ""}`}>
          {tag}
        </span>
      ))}
    </div>
  </div>
  <span class={`pill ${pillClass}`}>{pillLabel[status][lang]}</span>
</div>

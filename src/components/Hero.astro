---
// src/components/Hero.astro
// Background image: place /public/hero.jpg — it will show behind the gradient mesh.
// Logo image: place /public/logo-horz.png for nav, /public/logo2.png for footer.
import { getCollection } from "astro:content";
import { type Lang } from "@/i18n/translations";

interface Props { lang: Lang }
const { lang } = Astro.props;

// Edit this when your society memberships change
const PARTNER_SOCIETIES = 3; // KSPAI, KIICE, KLife

const [research, curriculum, notes] = await Promise.all([
  getCollection("research"),
  getCollection("curriculum"),
  getCollection("notes"),
]);

const pubCount   = research.filter(r => !r.data.private).length;
const trackCount = curriculum.filter(t => !t.data.private).length;
const noteCount  = notes.filter(n => !n.data.private).length;
---

<div class="hero full-bleed">
  <!-- Gradient mesh (animated) — sits behind any bg image -->
  <div class="hero-bg" aria-hidden="true"></div>
  <!-- Circuit grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>
  <!-- Overlay: light in dark mode, heavier in light mode for text legibility -->
  <div class="hero-overlay" aria-hidden="true"></div>
  <!-- Fade to page bg at bottom -->
  <div class="hero-fade" aria-hidden="true"></div>

  <div class="container">
    <div class="hero-inner">
      <div>
        <p class="hero-eyebrow">
          {lang === "ko" ? "— 전주 · 대한민국 · 설립 2026" : "JEONJU · KOREA · EST. 2026"}
        </p>
        <h1>
          <span class="grad">{lang === "ko" ? "피지컬" : "Physical"}</span><br>
          {lang === "ko" ? "AI 연구소" : "AI Lab"}
        </h1>
        <p class="hero-tagline">
          {lang === "ko"
            ? "임베디드 시스템, 자율 로보틱스, 엣지 AI를 통해 기계 지능과 물리적 세계를 연결합니다."
            : "Bridging machine intelligence and the physical world — embedded systems, autonomous robotics, and real-time AI at the edge."}
        </p>
        <div class="hero-cta">
          <a href="#research" class="btn-primary">
            {lang === "ko" ? "연구 보기 →" : "View research →"}
          </a>
          <a href="#join" class="btn-slide btn-slide-cyan">
            {lang === "ko" ? "연구 기회" : "Research opportunities"}
          </a>
        </div>
      </div>

      <!-- Stat panel — data driven from content collections -->
      <div class="hero-panel">
        <div class="stat-row">
          <div class="stat-num">{pubCount}</div>
          <div class="stat-label">{lang === "ko" ? "출판 및 프리프린트" : "PUBLICATIONS & PREPRINTS"}</div>
        </div>
        <div class="stat-row">
          <div class="stat-num">{trackCount}</div>
          <div class="stat-label">{lang === "ko" ? "커리큘럼 트랙" : "CURRICULUM TRACKS"}</div>
        </div>
        <div class="stat-row">
          <div class="stat-num">{noteCount}</div>
          <div class="stat-label">{lang === "ko" ? "노트 및 아티클" : "NOTES & ARTICLES"}</div>
        </div>
        <div class="stat-row">
          <div class="stat-num">{PARTNER_SOCIETIES}</div>
          <div class="stat-label">{lang === "ko" ? "파트너 학회" : "PARTNER SOCIETIES"}</div>
        </div>
      </div>
    </div>
  </div>
</div>

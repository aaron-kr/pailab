---
/**
 * SiteSearch.astro
 * Drop this anywhere in your nav or as a standalone search page.
 * Pagefind runs at build time: `npx pagefind --site dist`
 * (or wire it into your build script — see README additions below)
 *
 * Usage:
 *   import SiteSearch from "@/components/SiteSearch.astro";
 *   <SiteSearch />
 *
 * For a full /search page, use SearchPage.astro (also generated).
 */

interface Props {
  /** Show as a compact icon-trigger (nav bar) or full expanded box (search page) */
  variant?: "compact" | "full";
}

const { variant = "compact" } = Astro.props;
---

{variant === "compact" ? (
  <!-- Compact: button that opens the full search overlay -->
  <button
    id="search-trigger"
    class="btn-ghost search-trigger"
    aria-label="Search"
    type="button"
  >
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
      <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <span>Search</span>
  </button>

  <div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
    <div class="search-backdrop"></div>
    <div class="search-modal">
      <div class="search-input-row">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="search-icon">
          <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input
          id="pagefind-search-input"
          type="search"
          placeholder="Search notes, projects, research…"
          autocomplete="off"
          class="search-input"
        />
        <kbd class="search-esc" aria-label="Press Escape to close">Esc</kbd>
      </div>
      <div id="pagefind-results" class="search-results"></div>
    </div>
  </div>
) : (
  <!-- Full: expanded search box for /search page -->
  <div class="search-full">
    <div class="search-input-row search-input-row--full">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="search-icon">
        <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        id="pagefind-search-input"
        type="search"
        placeholder="Search notes, projects, research…"
        autocomplete="off"
        class="search-input"
      />
    </div>
    <div id="pagefind-results" class="search-results search-results--full"></div>
  </div>
)}

<script>
  let pf: any = null;

  async function initPagefind(inputId: string, resultsId: string) {
    if (pf) return;
    try {
      // Load pagefind via script tag — bypasses Vite's import analysis entirely
      await new Promise<void>((resolve, reject) => {
        if ((window as any).PagefindUI) { resolve(); return; }
        const s = document.createElement("script");
        s.src = "/pagefind/pagefind-ui.js";
        s.onload = () => resolve();
        s.onerror = () => reject();
        document.head.appendChild(s);
      });
      // Load CSS once
      if (!document.querySelector('link[href="/pagefind/pagefind-ui.css"]')) {
        const link = document.createElement("link");
        link.rel = "stylesheet";
        link.href = "/pagefind/pagefind-ui.css";
        document.head.appendChild(link);
      }
      pf = new (window as any).PagefindUI({
        element: `#${resultsId}`,
        showSubResults: true,
        resetStyles: false,
        highlightParam: "highlight",
      });
      const input = document.getElementById(inputId) as HTMLInputElement | null;
      if (!input) return;
      input.addEventListener("input", () => pf.triggerSearch(input.value));
    } catch {
      // Dev mode — pagefind not built yet, fail silently
    }
  }

  // ── Compact overlay variant ──────────────────────────
  const trigger  = document.getElementById("search-trigger");
  const overlay  = document.getElementById("search-overlay") as HTMLElement | null;
  const backdrop = overlay?.querySelector(".search-backdrop");

  function openSearch() {
    if (!overlay) return;
    overlay.hidden = false;
    document.body.style.overflow = "hidden";
    const input = document.getElementById("pagefind-search-input") as HTMLInputElement | null;
    initPagefind("pagefind-search-input", "pagefind-results").then(() => input?.focus());
  }

  function closeSearch() {
    if (!overlay) return;
    overlay.hidden = true;
    document.body.style.overflow = "";
  }

  trigger?.addEventListener("click", openSearch);
  backdrop?.addEventListener("click", closeSearch);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === "k") { e.preventDefault(); openSearch(); }
  });

  // ── Full variant (search page) ───────────────────────
  if (document.getElementById("pagefind-search-input") && !trigger) {
    initPagefind("pagefind-search-input", "pagefind-results");
    (document.getElementById("pagefind-search-input") as HTMLInputElement | null)?.focus();
  }
</script>

<style>
/* ── Search trigger ──────────────────────────────────── */
.search-trigger {
  display: flex;
  align-items: center;
  gap: 6px;
}

/* ── Overlay shell ───────────────────────────────────── */
.search-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 12vh;
  display: none;
}

.search-overlay:not([hidden]) {
  display: flex;
}

.search-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 8, 20, .72);
  backdrop-filter: blur(4px);
}

.search-modal {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 640px;
  margin: 0 1rem;
  background: var(--bg-surface);
  border: .5px solid var(--border-2);
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(2, 8, 20, .6);
}

/* ── Input row ───────────────────────────────────────── */
.search-input-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: .875rem 1.25rem;
  border-bottom: .5px solid var(--border);
}

.search-input-row--full {
  background: var(--bg-surface);
  border: .5px solid var(--border-2);
  border-radius: var(--r-lg);
  margin-bottom: 1.5rem;
}

.search-icon {
  color: var(--text-3);
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  font-family: var(--font-body);
  font-size: .9rem;
  color: var(--text);
}
.search-input::placeholder {
  color: var(--text-3);
}

.search-esc {
  font-family: var(--font-mono);
  font-size: .58rem;
  color: var(--text-3);
  border: .5px solid var(--border-2);
  border-radius: 4px;
  padding: 2px 6px;
  flex-shrink: 0;
}

/* ── Results ─────────────────────────────────────────── */
.search-results {
  max-height: 480px;
  overflow-y: auto;
  padding: .5rem 0;
}

.search-results--full {
  max-height: none;
}

/* Override Pagefind UI default styles to match site design */
.search-results :global(.pagefind-ui__result) {
  padding: .875rem 1.25rem;
  border-bottom: .5px solid var(--border);
}
.search-results :global(.pagefind-ui__result:last-child) {
  border-bottom: none;
}
.search-results :global(.pagefind-ui__result-title a) {
  font-family: var(--font-display);
  font-size: .9rem;
  font-weight: 600;
  color: var(--text);
}
.search-results :global(.pagefind-ui__result-title a:hover) {
  color: var(--green);
}
.search-results :global(.pagefind-ui__result-excerpt) {
  font-size: .78rem;
  color: var(--text-2);
  line-height: 1.6;
  margin-top: .35rem;
}
.search-results :global(mark) {
  background: rgba(36, 255, 252, .2);
  color: var(--cyan);
  border-radius: 2px;
  padding: 0 2px;
}
.search-results :global(.pagefind-ui__message) {
  font-family: var(--font-mono);
  font-size: .72rem;
  color: var(--text-3);
  padding: 1rem 1.25rem;
  text-align: center;
}

/* Scrollbar */
.search-results::-webkit-scrollbar { width: 4px; }
.search-results::-webkit-scrollbar-track { background: transparent; }
.search-results::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 2px; }
</style>

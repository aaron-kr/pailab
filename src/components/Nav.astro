---
// src/components/Nav.astro
// Changes from previous version:
// • Hamburger menu for mobile (≤640px)
// • Mobile overlay panel with all nav items + controls
// • Search button wired to SiteSearch component
import { altLangUrl, type Lang } from "@/i18n/translations";
import SiteSearch from "@/components/SiteSearch.astro";

interface Props { lang: Lang; currentPath: string; }
const { lang, currentPath } = Astro.props;
const altUrl = altLangUrl(currentPath, lang);
const p = lang === "ko" ? "/ko" : "";

// ── EDIT THIS to change the nav structure ───────────────────
const NAV: Array<
  | { label: string; href: string; hideOnKo?: boolean }
  | { label: string; items: { label: string; href: string }[] }
> = [
  {
    label: "Research",
    items: [
      { label: "Areas",       href: `${p}/areas` },
      { label: "Papers",      href: `${p}/research` },
      { label: "Projects",    href: `${p}/projects` },
    ],
  },
  {
    label: "Learn",
    items: [
      { label: "Curriculum",  href: `${p}/curriculum` },
      { label: "Modules",     href: `${p}/modules` },
      { label: "Notes",       href: `${p}/notes` },
    ],
  },
  { label: "Team",  href: `/team` },
  { label: "Join",  href: `${p}/join` },
  { label: "About", href: `${p}/about` },
  { label: "Search", href: "/search", hideOnKo: false },
];
// ────────────────────────────────────────────────────────────
---

<nav class="site-nav">
  <div class="nav-inner container">

    <a href={`${p}/`} class="nav-logo">
      <img src="/logo-horz.png" alt="PAI LAB" class="nav-logo-img" />
      <span class="sub">{lang === "ko" ? "피지컬 AI 연구소" : "Physical AI Lab"}</span>
    </a>

    <!-- Desktop nav links -->
    <ul class="nav-links">
      {NAV.map((item) => {
        if ("href" in item) {
          return (
            <li>
              <a href={item.href}
                 class:list={["nav-link", { "nav-link--active": currentPath === item.href || currentPath.startsWith(item.href + "/") }]}>
                {item.label}
              </a>
            </li>
          );
        } else {
          const isGroupActive = item.items.some(i =>
            currentPath === i.href || currentPath.startsWith(i.href + "/")
          );
          return (
            <li class="nav-dropdown-wrap">
              <button
                class:list={["nav-link nav-dropdown-trigger", { "nav-link--active": isGroupActive }]}
                aria-expanded="false"
                aria-haspopup="true"
                type="button"
              >
                {item.label}
                <svg class="nav-chevron" width="9" height="5" viewBox="0 0 9 5" fill="none" aria-hidden="true">
                  <path d="M1 1l3.5 3L8 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
              <ul class="nav-dropdown" role="menu">
                {item.items.map((sub) => (
                  <li role="none">
                    <a href={sub.href} class="nav-dropdown-item" role="menuitem"
                       class:list={["nav-dropdown-item", { "nav-dropdown-item--active": currentPath === sub.href }]}>
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          );
        }
      })}
    </ul>

    <!-- Controls (desktop + mobile) -->
    <div class="nav-controls">
      <SiteSearch variant="compact" />
      <span class="nav-sep" aria-hidden="true"></span>
      <a href={altUrl} class="btn-ghost" aria-label="Switch language">
        {lang === "en" ? "한국어" : "EN"}
      </a>
      <span class="nav-sep" aria-hidden="true"></span>
      <button id="theme-toggle" class="btn-ghost" aria-label="Toggle theme" style="min-width:2rem;">☀</button>
      <!-- Auth control: shows lock when logged-out, avatar+dropdown when logged-in -->
      <a href="/login" class="btn-ghost nav-lock-btn" id="nav-login-btn" aria-label="Sign in">🔒</a>
      <div class="nav-dropdown-wrap nav-user-wrap" id="nav-user-wrap" style="display:none">
        <button class="nav-user-btn nav-dropdown-trigger" id="nav-user-btn"
                aria-label="Account menu" aria-expanded="false" aria-haspopup="true" type="button">
          <span id="nav-avatar-inner" class="nav-avatar"></span>
        </button>
        <ul class="nav-dropdown nav-user-menu" role="menu">
          <li role="none">
            <a href="/members" class="nav-dropdown-item" role="menuitem">Members area ↗</a>
          </li>
          <li role="none" aria-hidden="true">
            <div class="nav-menu-divider"></div>
          </li>
          <li role="none">
            <button class="nav-dropdown-item nav-signout-item" id="nav-signout-btn"
                    role="menuitem" type="button">Sign out</button>
          </li>
        </ul>
      </div>
      <!-- Hamburger — hidden on desktop via CSS -->
      <button id="hamburger" class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" type="button">
        <span class="ham-bar"></span>
        <span class="ham-bar"></span>
        <span class="ham-bar"></span>
      </button>
    </div>

  </div>
</nav>

<!-- ── Mobile menu overlay ──────────────────────────────────── -->
<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <div class="mobile-backdrop" id="mobile-backdrop"></div>
  <div class="mobile-panel">

    <div class="mobile-panel-top">
      <a href={`${p}/`} class="nav-logo">
        <img src="/logo-horz.png" alt="PAI LAB" class="nav-logo-img" />
      </a>
      <button class="mobile-close" id="mobile-close" aria-label="Close menu">✕</button>
    </div>

    <nav class="mobile-nav-links">
      {NAV.map((item) => {
        if ("href" in item) {
          return (
            <a href={item.href}
               class:list={["mobile-nav-link", { "mobile-nav-link--active": currentPath === item.href }]}>
              {item.label}
            </a>
          );
        } else {
          return (
            <div class="mobile-nav-group">
              <span class="mobile-group-label">{item.label}</span>
              {item.items.map((sub) => (
                <a href={sub.href}
                   class:list={["mobile-nav-link mobile-nav-link--sub", { "mobile-nav-link--active": currentPath === sub.href }]}>
                  {sub.label}
                </a>
              ))}
            </div>
          );
        }
      })}
    </nav>

    <div class="mobile-panel-bottom">
      <a href={altUrl} class="btn-ghost" style="flex:1; justify-content:center; text-align:center;">
        {lang === "en" ? "한국어" : "EN"}
      </a>
      <button id="mobile-theme-toggle" class="btn-ghost" aria-label="Toggle theme" style="flex:1; min-width:0;">☀ Theme</button>
    </div>

  </div>
</div>

<script>
// ── Desktop dropdown ─────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>(".nav-dropdown-trigger").forEach(btn => {
  btn.addEventListener("click", (e) => {
    e.stopPropagation();
    const wrap = btn.closest(".nav-dropdown-wrap")!;
    const isOpen = wrap.classList.contains("open");
    document.querySelectorAll(".nav-dropdown-wrap.open").forEach(w => {
      w.classList.remove("open");
      (w.querySelector(".nav-dropdown-trigger") as HTMLElement)?.setAttribute("aria-expanded", "false");
    });
    if (!isOpen) {
      wrap.classList.add("open");
      btn.setAttribute("aria-expanded", "true");
    }
  });
});
document.addEventListener("click", () => {
  document.querySelectorAll(".nav-dropdown-wrap.open").forEach(w => {
    w.classList.remove("open");
    (w.querySelector(".nav-dropdown-trigger") as HTMLElement)?.setAttribute("aria-expanded", "false");
  });
});
document.addEventListener("keydown", e => {
  if (e.key === "Escape") {
    document.querySelectorAll(".nav-dropdown-wrap.open").forEach(w => w.classList.remove("open"));
    closeMobileMenu();
  }
});

// ── Mobile hamburger ─────────────────────────────────────────
const hamburger   = document.getElementById("hamburger")!;
const mobileMenu  = document.getElementById("mobile-menu")!;
const mobileClose = document.getElementById("mobile-close")!;
const backdrop    = document.getElementById("mobile-backdrop")!;

function openMobileMenu() {
  mobileMenu.classList.add("open");
  mobileMenu.setAttribute("aria-hidden", "false");
  hamburger.setAttribute("aria-expanded", "true");
  hamburger.classList.add("is-open");
  document.body.style.overflow = "hidden";
}

function closeMobileMenu() {
  mobileMenu.classList.remove("open");
  mobileMenu.setAttribute("aria-hidden", "true");
  hamburger.setAttribute("aria-expanded", "false");
  hamburger.classList.remove("is-open");
  document.body.style.overflow = "";
}

hamburger.addEventListener("click", (e) => { e.stopPropagation(); openMobileMenu(); });
mobileClose.addEventListener("click", closeMobileMenu);
backdrop.addEventListener("click", closeMobileMenu);

// Close when any mobile nav link is clicked
document.querySelectorAll(".mobile-nav-link").forEach(link =>
  link.addEventListener("click", closeMobileMenu)
);

// Mobile theme toggle mirrors the main one
const mobileThemeBtn = document.getElementById("mobile-theme-toggle");
mobileThemeBtn?.addEventListener("click", () => {
  document.getElementById("theme-toggle")?.click();
});

// ── Firebase auth — login button / user avatar ────────────────
import { initializeApp, getApps, getApp } from "firebase/app";
import { getAuth, onAuthStateChanged, signOut } from "firebase/auth";

const _fbCfg = {
  apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
  appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID,
};
const _fbApp  = getApps().length === 0 ? initializeApp(_fbCfg) : getApp();
const _auth   = getAuth(_fbApp);

const _loginBtn  = document.getElementById("nav-login-btn")  as HTMLAnchorElement;
const _userWrap  = document.getElementById("nav-user-wrap")  as HTMLDivElement;
const _avatarEl  = document.getElementById("nav-avatar-inner") as HTMLSpanElement;
const _signoutBtn = document.getElementById("nav-signout-btn") as HTMLButtonElement;

onAuthStateChanged(_auth, (user) => {
  if (user) {
    // ── Logged in ─────────────────────────────────────────────
    _loginBtn.style.display = "none";
    _userWrap.style.display = "";

    // Render avatar: photo or initials
    if (user.photoURL) {
      _avatarEl.innerHTML =
        `<img src="${user.photoURL}" alt="${user.displayName ?? ""}" class="nav-avatar-img" referrerpolicy="no-referrer" />`;
    } else {
      _avatarEl.textContent = (user.displayName ?? user.email ?? "?")
        .split(" ").map((n: string) => n[0]).join("").slice(0, 2).toUpperCase();
    }

    // Reveal private list items on public listing pages
    document.querySelectorAll<HTMLElement>('[data-private="true"]').forEach(el => {
      el.removeAttribute("data-private");
    });

    // Reveal private detail page (body was hidden in BaseLayout)
    if (document.body.dataset.privatePage === "true") {
      document.body.style.visibility = "visible";
    }

  } else {
    // ── Logged out ────────────────────────────────────────────
    _loginBtn.style.display = "";
    _userWrap.style.display = "none";

    // Private detail page: redirect to login instead of showing blank page
    if (document.body.dataset.privatePage === "true") {
      const next = encodeURIComponent(window.location.pathname);
      window.location.replace(`/login?next=${next}`);
    }
  }
});

// Sign out handler
_signoutBtn?.addEventListener("click", async () => {
  sessionStorage.removeItem("pailab-role");
  sessionStorage.removeItem("pailab-uid");
  try { await signOut(_auth); } catch {}
  window.location.href = "/";
});
</script>

<style>
/* ── Nav link baseline — applies to BOTH anchors AND dropdown button ── */
.nav-link {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  height: var(--nav-h, 60px);
  padding: 0 .6rem;
  font-family: var(--font-body);
  font-size: .78rem;
  font-weight: 400;
  color: var(--text-2);
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
  line-height: 1;
  transition: color .15s;
  -webkit-appearance: none;
  appearance: none;
  vertical-align: middle;
}
.nav-link:hover,
.nav-link--active { color: var(--text); text-decoration: none; }

.nav-chevron { transition: transform .18s ease; flex-shrink: 0; opacity: .55; margin-top: 1px; }
.nav-dropdown-wrap.open .nav-chevron { transform: rotate(180deg); }

/* ── Dropdown panel ─────────────────────────────────────────── */
.nav-dropdown-wrap { position: relative; }

.nav-dropdown {
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
  position: absolute;
  top: calc(100% - 2px);
  left: 50%;
  transform: translateX(-50%) translateY(-4px);
  min-width: 148px;
  background: var(--bg-surface);
  border: .5px solid var(--border-2);
  border-radius: var(--r-lg, 14px);
  box-shadow: 0 8px 24px rgba(0,0,0,.18);
  padding: .375rem;
  z-index: 200;
  list-style: none;
  transition: opacity .14s ease, transform .14s ease, visibility 0s .14s;
}
.nav-dropdown::before {
  content: '';
  position: absolute;
  top: -4px; left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 7px; height: 7px;
  background: var(--bg-surface);
  border-left: .5px solid var(--border-2);
  border-top: .5px solid var(--border-2);
}
.nav-dropdown-wrap.open .nav-dropdown {
  visibility: visible;
  opacity: 1;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
  transition: opacity .14s ease, transform .14s ease;
}

.nav-dropdown-item {
  display: block;
  padding: .45rem .875rem;
  font-size: .78rem;
  color: var(--text-2);
  text-decoration: none;
  border-radius: var(--r-sm, 6px);
  white-space: nowrap;
  transition: background .1s, color .1s;
}
.nav-dropdown-item:hover,
.nav-dropdown-item--active {
  background: var(--bg-subtle);
  color: var(--text);
  text-decoration: none;
}
[data-theme="dark"] .nav-dropdown-item:hover { color: var(--cyan, #24fffc); background: rgba(36,255,252,.07); }
[data-theme="dark"] .nav-dropdown { box-shadow: 0 8px 28px rgba(0,0,0,.45), 0 0 0 .5px rgba(36,255,252,.08); }

/* ── Controls ───────────────────────────────────────────────── */
.nav-sep { display: inline-block; width: .5px; height: 14px; background: var(--border-2); vertical-align: middle; flex-shrink: 0; }

/* ── Hamburger button ───────────────────────────────────────── */
.hamburger {
  display: none;          /* hidden on desktop */
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 34px; height: 34px;
  background: none;
  border: .5px solid var(--border-2);
  border-radius: var(--r-sm);
  cursor: pointer;
  padding: 0;
  transition: border-color .15s;
}
.hamburger:hover { border-color: var(--cyan); }
.ham-bar {
  display: block;
  width: 16px; height: 1.5px;
  background: var(--text-2);
  border-radius: 1px;
  transition: transform .2s, opacity .15s, width .2s;
}
.hamburger.is-open .ham-bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hamburger.is-open .ham-bar:nth-child(2) { opacity: 0; width: 0; }
.hamburger.is-open .ham-bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* ── Mobile menu ────────────────────────────────────────────── */
.mobile-menu {
  display: none;  /* js adds .open which uses flex */
  position: fixed;
  inset: 0;
  z-index: 500;
}
.mobile-menu.open { display: flex; }

.mobile-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 8, 20, .72);
  backdrop-filter: blur(4px);
}

.mobile-panel {
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: min(300px, 85vw);
  background: var(--bg-surface);
  border-left: .5px solid var(--border-2);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform .25s cubic-bezier(.4, 0, .2, 1);
  overflow-y: auto;
  box-shadow: -8px 0 32px rgba(2, 8, 20, .5);
}
.mobile-menu.open .mobile-panel {
  transform: translateX(0);
}

.mobile-panel-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.25rem;
  border-bottom: .5px solid var(--border);
  flex-shrink: 0;
}
.mobile-close {
  background: none; border: none;
  color: var(--text-2); font-size: 1rem;
  cursor: pointer; padding: 6px;
  transition: color .15s;
}
.mobile-close:hover { color: var(--pink); }

.mobile-nav-links {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: .75rem 0;
  overflow-y: auto;
}

.mobile-nav-group {
  display: flex;
  flex-direction: column;
  padding: .5rem 0;
  border-bottom: .5px solid var(--border);
}
.mobile-nav-group:last-child { border-bottom: none; }

.mobile-group-label {
  font-family: var(--font-mono);
  font-size: .58rem;
  color: var(--text-3);
  letter-spacing: .1em;
  padding: .4rem 1.25rem .25rem;
  text-transform: uppercase;
}

.mobile-nav-link {
  display: block;
  padding: .6rem 1.25rem;
  font-size: .88rem;
  color: var(--text-2);
  text-decoration: none;
  transition: background .1s, color .1s;
  border: none;
}
.mobile-nav-link--sub {
  padding-left: 2rem;
  font-size: .82rem;
}
.mobile-nav-link:hover { background: var(--bg-subtle); color: var(--text); text-decoration: none; }
.mobile-nav-link--active { color: var(--cyan); }
[data-theme="light"] .mobile-nav-link--active { color: var(--green-2); }

.mobile-panel-bottom {
  display: flex;
  gap: .75rem;
  padding: 1rem 1.25rem;
  border-top: .5px solid var(--border);
  flex-shrink: 0;
}

/* Show hamburger, hide nav-links on mobile */
@media (max-width: 640px) {
  .hamburger { display: flex; }
  .nav-links { display: none; }
  /* Also hide the nav-sep before the lang toggle on very small screens */
  .nav-controls .nav-sep:first-of-type { display: none; }
}

/* ── Auth: user avatar button ───────────────────────────────── */
.nav-user-btn {
  background: none; border: none;
  padding: 0; cursor: pointer;
  display: flex; align-items: center;
}

.nav-avatar {
  display: flex; align-items: center; justify-content: center;
  width: 30px; height: 30px; border-radius: 50%;
  background: rgba(36,180,255,.18);
  border: 1.5px solid rgba(36,180,255,.35);
  font-family: var(--font-display); font-size: .62rem; font-weight: 700;
  color: var(--cyan); overflow: hidden;
  transition: border-color .15s, box-shadow .15s;
}
.nav-user-btn:hover .nav-avatar,
.nav-user-wrap.open .nav-avatar {
  border-color: var(--cyan);
  box-shadow: 0 0 0 2px rgba(36,255,252,.15);
}
.nav-avatar-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  border-radius: 50%;
}

/* ── User menu: right-aligned, no centering arrow ───────────── */
.nav-user-menu {
  left: auto !important;
  right: 0 !important;
  transform: translateX(0) translateY(-4px) !important;
}
.nav-user-wrap.open .nav-user-menu {
  transform: translateX(0) translateY(0) !important;
}
/* Hide the center-pointing arrow diamond for user menu */
.nav-user-menu::before { display: none; }

.nav-menu-divider {
  height: .5px; background: var(--border);
  margin: .25rem .5rem;
}

/* Sign-out item — danger colouring */
.nav-signout-item {
  width: 100%; text-align: left;
  background: none; border: none;
  font-size: .78rem; font-family: var(--font-body);
  color: rgba(240,18,122,.8) !important;
}
.nav-signout-item:hover {
  color: var(--pink) !important;
  background: rgba(240,18,122,.08) !important;
}
</style>

---
// src/components/ResearchAreas.astro
import { getCollection } from "astro:content";
import { type Lang } from "@/i18n/translations";

interface Props { lang: Lang }
const { lang } = Astro.props;

const areas = (await getCollection("areas")).sort((a, b) => a.data.order - b.data.order);
---

<div class="areas-index">
  {areas.map((area, i) => {
    if (area.data.hidden) return null; // Skip hidden areas
    const num   = String(i + 1).padStart(2, "0");
    const title = (lang === "ko" && area.data.title_ko) ? area.data.title_ko : area.data.title;
    const desc  = (lang === "ko" && area.data.description_ko) ? area.data.description_ko : area.data.description;
    const href  = area.data.href ?? `/notes/category/${area.id}`;
    return (
      <a href={href} class="area-index-item">
        <p class="ain">{num}</p>
        <span>{area.data.icon}</span>
        <p class="ait">{title}</p>
        <p class="area-desc">{desc}</p>
      </a>
    );
  })}
</div>

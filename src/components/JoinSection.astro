---
// src/components/JoinSection.astro
import { type Lang } from "@/i18n/translations";
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<div class="join-section full-bleed" id="join">
  <div class="container">
    <div class="join-inner">
      <div>
        <p class="join-eyebrow">
          {lang === "ko" ? "연구 기회" : "RESEARCH OPPORTUNITIES"}
        </p>
        <h2 class="join-title">
          {lang === "ko" ? "연구소와 함께 일하기" : "Work with the lab"}
        </h2>
        <p class="join-sub">
          {lang === "ko"
            ? "저는 학회 논문, 오픈 데이터셋, 피지컬 AI 프로젝트(Arduino 로보틱스, 엣지 ML, 임베디드 시스템)에 관심 있는 학부생들과 함께 연구합니다. AI 배경 지식이 없어도 됩니다. 가능성 있는 캡스톤 프로젝트가 있거나, 실제로 무언가를 만들면서 배우고 싶다면 연락주세요."
            : "I work with motivated undergraduates on conference papers, open datasets, and Physical AI projects — Arduino robotics, edge ML, embedded systems. No prior AI background required. If you have a capstone project with potential, or just want to learn by building something real, reach out."}
        </p>
      </div>
      <div class="join-cta">
        <a href="https://aaronsnowberger.com" class="btn-primary">
          {lang === "ko" ? "연락하기 →" : "Get in touch →"}
        </a>
        <a href="#about" class="btn-slide btn-slide-cyan" style="text-align:center">
          {lang === "ko" ? "연구소 소개" : "About the lab"}
        </a>
      </div>
    </div>
  </div>
</div>

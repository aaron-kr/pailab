---
// src/pages/team.astro
// Public-facing team page.
// Reads from Firestore users collection (client-side, public fields only).
// Only shows members with public_profile: true.
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
---

<BaseLayout
  lang="en"
  title="Team · PAI LAB"
  description="The people of the Physical AI Laboratory — researchers, students, and collaborators."
>
  <PageHeader
    title="Team"
    eyebrow="PEOPLE"
    description="The researchers and students building Physical AI at the PAI Lab."
  />

  <div class="container page-content">

    <!-- PI card (static — always shown) -->
    <section style="margin-bottom:3rem;">
      <h2 class="team-section-label">Principal Investigator</h2>
      <div class="pi-card card">
        <div class="pi-avatar">
          <img
            src="https://res.cloudinary.com/dobann7wi/image/upload/q_auto/f_auto/v1776419032/default_ps8fsj.jpg"
            alt="Aaron Snowberger"
            style="overflow:hidden; width:100%; height:100%; object-fit:cover;border-radius: 50%;padding:4px;"
          />
        </div>
        <div class="pi-info">
          <h3 class="pi-name">Aaron Snowberger</h3>
          <p class="pi-title">Principal Investigator · Physical AI Laboratory</p>
          <p class="pi-bio" style="margin:.625rem 0 .875rem;">
            Researcher in embedded systems, edge ML, and physical AI education.
            Working at the intersection of intelligent software and real-world hardware.
          </p>
          <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:.875rem;">
            <span class="tag accent">Physical AI</span>
            <span class="tag">Edge ML</span>
            <span class="tag">Robotics</span>
            <span class="tag">Education</span>
          </div>
          <div style="display:flex; gap:12px; flex-wrap:wrap;">
            <a href="https://aaron.kr"                          class="team-link">aaron.kr ↗</a>
            <a href="https://kspai.org"                         class="team-link">KSPAI ↗</a>
            <a href="https://aaronkr-courses.github.io/courses/" class="team-link">Courses ↗</a>
            <a href="https://blog.naver.com/aaron_kr"           class="team-link">Naver Blog ↗</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Student members (loaded from Firestore) -->
    <section>
      <h2 class="team-section-label">Student Researchers</h2>
      <div id="team-members-grid" class="team-grid">
        <div class="team-loading">Loading members…</div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
import { initializeApp, getApps } from "firebase/app";
import { getFirestore, collection, getDocs, query, where } from "firebase/firestore";

// Minimal init from env vars (same config as @/lib/firebase)
let fbApp = getApps()[0];
if (!fbApp) {
  fbApp = initializeApp({
    apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY,
    authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
    projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
    storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
    messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
    appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID,
  });
}
const db = getFirestore(fbApp);

async function loadTeam() {
  const container = document.getElementById("team-members-grid")!;
  try {
    const q = query(
      collection(db, "users"),
      where("public_profile", "==", true),
      where("role", "==", "member")
    );
    const snap = await getDocs(q);

    if (snap.empty) {
      container.innerHTML = `<p style="color:var(--text-3); font-size:.85rem;">Student profiles coming soon.</p>`;
      return;
    }

    container.innerHTML = "";
    for (const d of snap.docs) {
      const m = d.data();
      const initials = (m.displayName ?? "?")
        .split(" ").map((n: string) => n[0]).join("").slice(0,2).toUpperCase();

      const card = document.createElement("div");
      card.className = "team-card card";
      card.innerHTML = `
        <div class="member-avatar"${m.photoURL ? ` style="background-image:url(${m.photoURL});background-size:cover;"` : ""}>
          ${m.photoURL ? "" : `<span>${initials}</span>`}
        </div>
        <div class="member-info">
          <h3 class="member-name">${m.displayName ?? "—"}</h3>
          <p class="member-uni">${m.university ?? ""} · ${m.major ?? ""}</p>
          ${m.bio ? `<p class="member-bio">${m.bio}</p>` : ""}
          ${m.interests?.length ? `
            <div style="display:flex; gap:5px; flex-wrap:wrap; margin:.625rem 0;">
              ${m.interests.map((i: string) => `<span class="tag">${i}</span>`).join("")}
            </div>` : ""}
          <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:.625rem;">
            ${m.github   ? `<a href="${m.github}"   target="_blank" class="team-link">GitHub ↗</a>` : ""}
            ${m.scholar  ? `<a href="${m.scholar}"  target="_blank" class="team-link">Scholar ↗</a>` : ""}
            ${m.linkedin ? `<a href="${m.linkedin}" target="_blank" class="team-link">LinkedIn ↗</a>` : ""}
            ${m.website  ? `<a href="${m.website}"  target="_blank" class="team-link">Site ↗</a>` : ""}
          </div>
        </div>
      `;
      container.appendChild(card);
    }
  } catch (e) {
    container.innerHTML = `<p style="color:var(--text-3); font-size:.85rem;">Could not load team members.</p>`;
  }
}

loadTeam();
</script>

<style>
.team-section-label {
  font-family: var(--font-mono);
  font-size: .68rem; letter-spacing: .12em;
  color: var(--text-3); margin-bottom: 1.25rem;
}

/* PI card */
.pi-card {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 1.5rem;
  align-items: start;
}
.pi-avatar {
  width: 100px; height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--bg-subtle), var(--bg-deep));
  border: .5px solid var(--border-2);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 1.6rem; font-weight: 800;
  color: var(--cyan);
}
.pi-name { font-size: 1.05rem; font-weight: 600; margin-bottom: .25rem; }
.pi-title { font-family: var(--font-mono); font-size: .68rem; color: var(--text-3); letter-spacing: .06em; }
.pi-bio { font-size: .85rem; color: var(--text-2); line-height: 1.7; }

/* Members grid */
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.team-loading { color: var(--text-3); font-size: .85rem; }
.team-card { display: flex; flex-direction: column; gap: .75rem; }
.member-avatar {
  width: 72px; height: 72px;
  border-radius: 50%;
  background: var(--bg-subtle);
  border: .5px solid var(--border-2);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 1.2rem; font-weight: 700;
  color: var(--accent);
  overflow: hidden;
}
.member-name { font-size: .9rem; font-weight: 600; }
.member-uni { font-family: var(--font-mono); font-size: .65rem; color: var(--text-3); margin-top: 2px; }
.member-bio { font-size: .8rem; color: var(--text-2); line-height: 1.65; margin-top: .375rem; }

.team-link {
  font-family: var(--font-mono);
  font-size: .68rem;
  color: var(--accent);
  text-decoration: none;
}
.team-link:hover { text-decoration: underline; }

@media (max-width: 600px) {
  .pi-card { grid-template-columns: 1fr; }
}
</style>

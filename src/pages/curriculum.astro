---
// src/pages/curriculum.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const tracks = (await getCollection("curriculum")).sort((a,b) => a.data.order - b.data.order);

const levelColor: Record<string, string> = {
  beginner:     "var(--green-glow)",
  intermediate: "var(--cyan)",
  advanced:     "var(--blue)",
  open:         "rgba(208,228,240,.5)",
};
const levelLabel: Record<string, string> = {
  beginner:"Beginner", intermediate:"Intermediate", advanced:"Advanced", open:"Open"
};
---

<BaseLayout lang={lang} title="Curriculum · PAI LAB"
  description="Four structured tracks from first principles to advanced robotics.">
  <PageHeader title="Curriculum" eyebrow="02 · CURRICULUM"
    description="Four structured tracks from first principles to advanced robotics. All tracks are bilingual (EN / 한국어) and freely available." />

  <div class="curriculum-list container page-content">
    <div class="track-grid">
      {tracks.map(track => (
        <div class="track-card card" data-private={track.data.private ? "true" : undefined}>
          <!-- Top color bar (slides in on hover via CSS) -->
          <div class="track-bar" style={`--bar-color: ${levelColor[track.data.level] ?? "var(--cyan)"}`}></div>

          <div class="track-header">
            <span class="track-num">TRACK {track.data.track}</span>
            <span class="track-level" style={`color: ${levelColor[track.data.level] ?? "var(--text-3)"}`}>
              {levelLabel[track.data.level]}
            </span>
          </div>

          <h2 class="track-title">{track.data.title}</h2>
          {track.data.title_ko && <p class="track-ko">{track.data.title_ko}</p>}

          <p class="track-desc">{track.data.description}</p>

          <div class="track-footer">
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              <span class="tag">{track.data.units} units</span>
              {track.data.bilingual && <span class="tag accent">EN · 한국어</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>


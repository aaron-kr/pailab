---
// src/pages/curriculum.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const tracks = (await getCollection("curriculum")).sort((a,b) => a.data.order - b.data.order);

const levelColor: Record<string, string> = {
  beginner:     "var(--green-glow)",
  intermediate: "var(--cyan)",
  advanced:     "var(--blue)",
  open:         "rgba(208,228,240,.5)",
};
const levelLabel: Record<string, string> = {
  beginner:"Beginner", intermediate:"Intermediate", advanced:"Advanced", open:"Open"
};
---

<BaseLayout lang={lang} title="Curriculum · PAI LAB"
  description="Four structured tracks from first principles to advanced robotics.">
  <PageHeader title="Curriculum" eyebrow="02 · CURRICULUM"
    description="Four structured tracks from first principles to advanced robotics. All tracks are bilingual (EN / 한국어) and freely available." />

  <div class="container page-content">
    <div class="track-grid">
      {tracks.map(track => (
        <div class="track-card card">
          <!-- Top color bar (slides in on hover via CSS) -->
          <div class="track-bar" style={`--bar-color: ${levelColor[track.data.level] ?? "var(--cyan)"}`}></div>

          <div class="track-header">
            <span class="track-num">TRACK {track.data.track}</span>
            <span class="track-level" style={`color: ${levelColor[track.data.level] ?? "var(--text-3)"}`}>
              {levelLabel[track.data.level]}
            </span>
          </div>

          <h2 class="track-title">{track.data.title}</h2>
          {track.data.title_ko && <p class="track-ko">{track.data.title_ko}</p>}

          <p class="track-desc">{track.data.description}</p>

          <div class="track-footer">
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              <span class="tag">{track.data.units} units</span>
              {track.data.bilingual && <span class="tag accent">EN · 한국어</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.track-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:1.25rem; }
.track-card {
  position:relative; overflow:hidden; padding:1.5rem;
  display:flex; flex-direction:column;
  transition: border-color .2s, transform .2s;
}
.track-card:hover { border-color:var(--border-2); transform:translateY(-3px); }

/* Sliding top bar */
.track-bar {
  position:absolute; top:0; left:0; right:0; height:2.5px;
  background:linear-gradient(90deg, var(--bar-color), color-mix(in srgb, var(--bar-color) 60%, transparent));
  transform:scaleX(0); transform-origin:left;
  transition:transform .32s cubic-bezier(.4,0,.2,1);
}
.track-card:hover .track-bar { transform:scaleX(1); }

.track-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:.875rem; }
.track-num   { font-family:var(--font-mono); font-size:.62rem; color:var(--text-3); letter-spacing:.1em; }
.track-level { font-family:var(--font-mono); font-size:.62rem; font-weight:500; letter-spacing:.08em; }
.track-title { font-size:.95rem; font-weight:600; margin-bottom:.375rem; line-height:1.3; }
.track-ko    { font-size:.75rem; color:var(--text-3); margin-bottom:.75rem; }
.track-desc  { font-size:.8rem; color:var(--text-2); line-height:1.65; flex:1; margin-bottom:1rem; }
.track-footer { margin-top:auto; }
</style>

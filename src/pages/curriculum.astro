---
// src/pages/curriculum.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const tracks = (await getCollection("curriculum")).sort(
  (a, b) => a.data.order - b.data.order
);

const levelLabel: Record<string, string> = {
  beginner:     "Beginner",
  intermediate: "Intermediate",
  advanced:     "Advanced",
  open:         "Open",
};
const levelDesc: Record<string, string> = {
  beginner:     "No prerequisites.",
  intermediate: "Basic programming recommended.",
  advanced:     "Math / ML background helpful.",
  open:         "Freely available. No prerequisites.",
};
---

<BaseLayout lang={lang} title="Curriculum · PAI LAB"
  description="Four structured tracks from first principles to advanced robotics.">

  <PageHeader
    title="Curriculum"
    eyebrow="02 · CURRICULUM"
    description="Four structured tracks from first principles to advanced robotics. All tracks are bilingual (EN / 한국어) and freely available."
  />

  <div class="container page-content">
    <div style="display:flex; flex-direction:column; gap:1.5rem;">
      {tracks.map((track) => (
        <div class="card" style="display:grid; grid-template-columns:160px 1fr; gap:2rem; align-items:start;">

          <div style="padding-top:.125rem;">
            <div style="font-family:var(--font-mono); font-size:.68rem; color:var(--text-3); margin-bottom:6px;">
              TRACK {track.data.track}
            </div>
            <div style="font-size:.72rem; font-weight:500; color:var(--cyan); margin-bottom:10px;">
              {levelLabel[track.data.level]}
            </div>
            <div style="display:flex; flex-direction:column; gap:5px;">
              <span class="tag">{track.data.units} units</span>
              {track.data.bilingual && <span class="tag accent">EN · 한국어</span>}
            </div>
            <p style="font-size:.68rem; color:var(--text-3); margin-top:10px; line-height:1.5;">
              {levelDesc[track.data.level]}
            </p>
          </div>

          <div>
            <h2 style="font-size:1.05rem; margin-bottom:.375rem;">{track.data.title}</h2>
            {track.data.title_ko && (
              <p style="font-size:.78rem; color:var(--text-2); margin-bottom:.75rem;">{track.data.title_ko}</p>
            )}
            <p style="font-size:.875rem; color:var(--text-2); line-height:1.65; margin-bottom:1rem;">
              {track.data.description}
            </p>
          </div>

        </div>
      ))}
    </div>
  </div>
</BaseLayout>

---
// src/pages/notes/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import NoteRow from "@/components/NoteRow.astro";
import { getCollection } from "astro:content";
import { t } from "@/i18n/translations";

const lang = "en" as const;
const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout lang={lang} title="Notes · PAI LAB"
  description="Lab updates, tutorials, and field notes from the Physical AI Laboratory.">

  <PageHeader
    title="Notes"
    eyebrow="05 · NOTES"
    description="Lab updates, tutorials, and field notes — in English and 한국어."
  />

  <div class="container page-content">
    <div class="row-list">
      {notes.map((note) => <NoteRow note={note} lang={lang} />)}
    </div>
  </div>
</BaseLayout>

---
// src/pages/notes/[slug].astro
import PostLayout from "@/layouts/PostLayout.astro";
import { render, getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const notes = (await getCollection("notes")).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return notes.map((note, index) => ({
    params: { slug: note.id },
    props: {
      note,
      prevPost: index < notes.length - 1
        ? { title: notes[index + 1].data.title, id: notes[index + 1].id }
        : undefined,
      nextPost: index > 0
        ? { title: notes[index - 1].data.title, id: notes[index - 1].id }
        : undefined,
    },
  }));
}

interface Props {
  note: CollectionEntry<"notes">;
  prevPost?: { title: string; id: string };
  nextPost?: { title: string; id: string };
}

const { note, prevPost, nextPost } = Astro.props;
const { Content } = await render(note);

const {
  title,
  title_ko,
  pubDate,
  tags,
  naver_url,
  lang: noteLang,
  summary,
  featuredImage,   // ← wide image above post body
  headerBgImage,   // ← subtle bg in the page header strip
  private: isPrivate,
} = note.data;

const lang = "en" as const;
---

<PostLayout
  title={title}
  title_ko={title_ko}
  description={summary}
  pubDate={pubDate}
  lang={lang}
  tags={tags}
  naverUrl={noteLang === "both" ? naver_url : undefined}
  prevPost={prevPost}
  nextPost={nextPost}
  featuredImage={featuredImage}
  headerBgImage={headerBgImage}
  privatePage={isPrivate}
>
  <Content />
</PostLayout>

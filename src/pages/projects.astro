---
// src/pages/projects.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ProjectRow from "@/components/ProjectRow.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout lang={lang} title="Projects · PAI LAB"
  description="Active hardware and software projects from the PAI Lab.">

  <PageHeader
    title="Projects"
    eyebrow="03 · PROJECTS"
    description="Active hardware and software projects — from gesture-controlled robotics to edge AI deployment pipelines."
  />

  <div class="container page-content">
    <div class="row-list">
      {projects.map((project) => <ProjectRow project={project} lang={lang} />)}
    </div>
  </div>
</BaseLayout>

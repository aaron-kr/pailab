---
// src/pages/admin/index.astro
import ProtectedLayout from "@/layouts/ProtectedLayout.astro";
import { getCollection } from "astro:content";

const papers   = await getCollection("research");
const projects = await getCollection("projects");
const notes    = await getCollection("notes");

const published  = papers.filter(p => p.data.status === "published").length;
const inReview   = papers.filter(p => p.data.status === "in-review").length;
const activeProj = projects.filter(p => p.data.status === "active").length;
---

<ProtectedLayout title="Admin Dashboard" area="admin" requireAdmin={true}>

  <div class="app-stat-grid" style="margin-bottom:1.75rem;">
    <div class="app-stat"><div class="app-stat-num">{published}</div><div class="app-stat-label">PUBLISHED PAPERS</div></div>
    <div class="app-stat"><div class="app-stat-num">{inReview}</div><div class="app-stat-label">IN REVIEW</div></div>
    <div class="app-stat"><div class="app-stat-num">{activeProj}</div><div class="app-stat-label">ACTIVE PROJECTS</div></div>
    <div class="app-stat"><div class="app-stat-num" id="stat-members"><span class="stat-loading">…</span></div><div class="app-stat-label">MEMBERS</div></div>
    <div class="app-stat"><div class="app-stat-num">{notes.length}</div><div class="app-stat-label">NOTES</div></div>
    <div class="app-stat"><div class="app-stat-num" id="stat-grants"><span class="stat-loading">…</span></div><div class="app-stat-label">ACTIVE GRANTS</div></div>
  </div>

  <div class="dash-grid">
    <a href="/admin/tracker"      class="app-card dash-shortcut"><span class="ds-icon">⊞</span><div><p class="app-card-title">RESEARCH TRACKER</p><p class="ds-desc">Track ideas, paper status, and deadlines.</p></div><span class="ds-arrow">→</span></a>
    <a href="/admin/members-list" class="app-card dash-shortcut"><span class="ds-icon">◉</span><div><p class="app-card-title">STUDENT ACCESS</p><p class="ds-desc">View member profiles and project assignments.</p></div><span class="ds-arrow">→</span></a>
    <a href="/admin/publications"  class="app-card dash-shortcut"><span class="ds-icon">📄</span><div><p class="app-card-title">PUBLICATIONS</p><p class="ds-desc">Manage paper records and DOI links.</p></div><span class="ds-arrow">→</span></a>
    <a href="/admin/grants"        class="app-card dash-shortcut"><span class="ds-icon">💰</span><div><p class="app-card-title">GRANT TRACKER</p><p class="ds-desc">Track funding applications and deadlines.</p></div><span class="ds-arrow">→</span></a>
    <a href="/admin/content"       class="app-card dash-shortcut"><span class="ds-icon">≡</span><div><p class="app-card-title">CONTENT</p><p class="ds-desc">Manage lab projects and templates.</p></div><span class="ds-arrow">→</span></a>
    <a href="/admin/settings"      class="app-card dash-shortcut"><span class="ds-icon">⚙</span><div><p class="app-card-title">SETTINGS</p><p class="ds-desc">Configure onboarding checklist.</p></div><span class="ds-arrow">→</span></a>
  </div>

  <div class="app-card" style="margin-top:1.5rem;">
    <p class="app-card-title">RECENT PAPERS</p>
    <div class="papers-list">
      {papers.sort((a,b) => b.data.year - a.data.year).slice(0,5).map(p => (
        <div class="paper-row">
          <div><p class="paper-title">{p.data.title}</p><p class="paper-meta">{p.data.venue} · {p.data.year}</p></div>
          <span class:list={["status-pill", `status-${p.data.status}`]}>{p.data.status}</span>
        </div>
      ))}
    </div>
    <a href="/admin/publications" class="view-all-link">All publications →</a>
  </div>

</ProtectedLayout>

<script>
  import { getFirestore, collection, getDocs, query, where } from "firebase/firestore";

  document.addEventListener("pailab:auth-ready", async (e: Event) => {
    const { db } = (e as CustomEvent).detail;

    // Member count
    try {
      const snap = await getDocs(query(collection(db, "users"), where("role", "==", "member")));
      document.getElementById("stat-members")!.textContent = String(snap.size);
    } catch { document.getElementById("stat-members")!.textContent = "—"; }

    // Active grants count
    try {
      const snap = await getDocs(query(collection(db, "grants"), where("status", "in", ["active","awarded"])));
      document.getElementById("stat-grants")!.textContent = String(snap.size);
    } catch { document.getElementById("stat-grants")!.textContent = "—"; }
  });
</script>

<style>
.dash-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
.dash-shortcut{display:flex;align-items:flex-start;gap:.875rem;text-decoration:none;transition:border-color .15s;cursor:pointer;}
.dash-shortcut:hover{border-color:rgba(36,180,255,.4);text-decoration:none;}
.ds-icon{font-size:1.3rem;flex-shrink:0;padding-top:.1rem;}
.ds-desc{font-size:.72rem;color:rgba(208,228,240,.45);margin-top:3px;line-height:1.5;}
.ds-arrow{color:var(--cyan);opacity:.35;font-size:1rem;margin-left:auto;padding-top:.1rem;}
.dash-shortcut:hover .ds-arrow{opacity:1;}
.papers-list{display:flex;flex-direction:column;}
.paper-row{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.65rem 0;border-bottom:.5px solid rgba(36,180,255,.07);}
.paper-row:last-child{border-bottom:none;}
.paper-title{font-size:.82rem;font-weight:500;margin-bottom:3px;}
.paper-meta{font-size:.68rem;color:rgba(208,228,240,.4);font-family:var(--font-mono);}
.status-published{color:var(--green-glow);border-color:var(--green-glow);}
.status-in-review{color:var(--cyan);border-color:var(--cyan);}
.status-preprint{color:var(--blue);border-color:var(--blue);}
.view-all-link{display:inline-block;margin-top:1rem;font-family:var(--font-mono);font-size:.68rem;color:var(--cyan);}
.stat-loading{color:rgba(208,228,240,.25);font-size:.7em;}
@media(max-width:900px){.dash-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.dash-grid{grid-template-columns:1fr;}}
</style>

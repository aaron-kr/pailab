---
// src/pages/admin/grants.astro
// All grant data stored in Firestore `grants` collection.
// Admin-only: Firestore rules should restrict to role === "admin".
import ProtectedLayout from "@/layouts/ProtectedLayout.astro";
---

<ProtectedLayout
  title="Grant Tracker"
  description="Track funding applications, deadlines, and status."
  area="admin"
  requireAdmin={true}
>

  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
    <p id="grant-count" style="font-family:var(--font-mono); font-size:.68rem; color:rgba(208,228,240,.4);"></p>
    <button class="btn-primary" id="add-grant-btn">+ Add grant</button>
  </div>

  <div style="display:flex; gap:.5rem; margin-bottom:1.25rem; flex-wrap:wrap;" id="filter-bar"></div>

  <div id="grants-list"><div class="loading-msg">Loading grants…</div></div>

  <!-- Modal -->
  <div class="modal-overlay" id="grant-modal" style="display:none;">
    <div class="modal app-card">
      <p class="app-card-title" id="modal-title">ADD GRANT</p>
      <input type="hidden" id="edit-grant-id" />
      <div class="form-grid">
        <div class="form-field form-field--full">
          <label class="form-label">Grant name / program</label>
          <input class="form-input" id="g-name" type="text" placeholder="NRF 신진연구자, NSF IRES, IITP…" />
        </div>
        <div class="form-field form-field--full">
          <label class="form-label">Funding agency</label>
          <input class="form-input" id="g-agency" type="text" placeholder="NRF, IITP, NVIDIA, NSF…" />
        </div>
        <div class="form-field">
          <label class="form-label">Amount</label>
          <input class="form-input" id="g-amount" type="text" placeholder="₩50,000,000" />
        </div>
        <div class="form-field">
          <label class="form-label">Status</label>
          <select class="form-input" id="g-status">
            <option value="planning">Planning</option>
            <option value="drafting">Drafting</option>
            <option value="submitted">Submitted</option>
            <option value="under-review">Under Review</option>
            <option value="awarded">Awarded</option>
            <option value="rejected">Rejected</option>
            <option value="active">Active (funded)</option>
            <option value="closed">Closed</option>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label">Deadline</label>
          <input class="form-input" id="g-deadline" type="date" />
        </div>
        <div class="form-field">
          <label class="form-label">Application URL</label>
          <input class="form-input" id="g-url" type="url" placeholder="https://…" />
        </div>
        <div class="form-field form-field--full">
          <label class="form-label">Notes</label>
          <textarea class="form-input" id="g-notes" rows="3"
            placeholder="Requirements, PI eligibility, co-investigators…"></textarea>
        </div>
      </div>
      <div style="display:flex; gap:.75rem; justify-content:flex-end; margin-top:1.25rem;">
        <button class="btn-ghost" id="close-modal">Cancel</button>
        <button class="btn-primary" id="save-grant-btn">Save</button>
      </div>
    </div>
  </div>

</ProtectedLayout>

<script>
import { getAuth, onAuthStateChanged } from "firebase/auth";
import {
  getFirestore, collection, getDocs, addDoc, doc, updateDoc, deleteDoc,
  serverTimestamp, Timestamp, query, orderBy
} from "firebase/firestore";
import { app } from "@/lib/firebase";

const auth = getAuth(app);
const db   = getFirestore(app);

const STATUS_COLORS: Record<string, string> = {
  planning:       "rgba(208,228,240,.4)",
  drafting:       "var(--blue)",
  submitted:      "var(--cyan)",
  "under-review": "var(--cyan)",
  awarded:        "var(--green-glow)",
  active:         "var(--green-glow)",
  rejected:       "var(--pink)",
  closed:         "rgba(208,228,240,.25)",
};

let currentFilter = "all";

onAuthStateChanged(auth, async (user) => {
  if (!user) return;
  await renderGrants();
});

async function renderGrants() {
  const container = document.getElementById("grants-list")!;
  container.innerHTML = `<div class="loading-msg">Loading…</div>`;

  const snap = await getDocs(query(collection(db, "grants"), orderBy("createdAt", "desc")));
  const grants = snap.docs.map(d => ({ id: d.id, ...d.data() } as any));

  // Count bar
  const countEl = document.getElementById("grant-count");
  if (countEl) countEl.textContent = `${grants.length} grant${grants.length !== 1 ? "s" : ""} tracked`;

  // Filter bar
  const filterBar = document.getElementById("filter-bar")!;
  const statuses  = ["all", ...Array.from(new Set(grants.map((g: any) => g.status as string)))];
  filterBar.innerHTML = "";
  for (const s of statuses) {
    const btn = document.createElement("button");
    btn.className = `filter-btn${s === currentFilter ? " active" : ""}`;
    const cnt = s === "all" ? grants.length : grants.filter((g: any) => g.status === s).length;
    btn.textContent = `${s} (${cnt})`;
    btn.addEventListener("click", () => { currentFilter = s; renderGrants(); });
    filterBar.appendChild(btn);
  }

  const filtered = currentFilter === "all" ? grants : grants.filter((g: any) => g.status === currentFilter);

  container.innerHTML = "";

  if (grants.length === 0) {
    container.innerHTML = `
      <div class="app-card" style="text-align:center; padding:3rem 2rem;">
        <p style="font-size:2rem; margin-bottom:1rem;">💰</p>
        <p style="font-size:.88rem; color:rgba(208,228,240,.5);">No grants tracked yet.</p>
        <p style="font-size:.75rem; color:rgba(208,228,240,.3); margin-top:.5rem;">
          Click "+ Add grant" to start tracking NRF, IITP, NVIDIA Inception, NSF, or other funding.
        </p>
      </div>`;
    return;
  }

  if (filtered.length === 0) {
    container.innerHTML = `<p class="loading-msg">No grants with status "${currentFilter}".</p>`;
    return;
  }

  for (const g of filtered) {
    const deadline = g.deadline
      ? new Date(g.deadline).toLocaleDateString("en-US", { year:"numeric", month:"short", day:"numeric" })
      : "—";
    const isLive = !["awarded","active","closed","rejected"].includes(g.status);
    const isPast  = g.deadline && new Date(g.deadline) < new Date() && isLive;
    const color   = STATUS_COLORS[g.status] ?? "rgba(208,228,240,.4)";

    const card = document.createElement("div");
    card.className = "app-card grant-card";
    card.innerHTML = `
      <div class="grant-header">
        <div>
          <p class="grant-name">${g.name ?? "Untitled"}</p>
          <p class="grant-agency">${g.agency ?? "—"}</p>
        </div>
        <div style="display:flex; gap:.5rem; align-items:center; flex-wrap:wrap;">
          ${g.amount ? `<span class="grant-amount">${g.amount}</span>` : ""}
          <span class="status-pill" style="color:${color}; border-color:${color};">${g.status}</span>
        </div>
      </div>
      <div class="grant-meta">
        <span class="${isPast ? "deadline-past" : ""}">⏱ ${deadline}${isPast ? " — OVERDUE" : ""}</span>
        ${g.url ? `<a href="${g.url}" target="_blank" class="pub-link">Application ↗</a>` : ""}
      </div>
      ${g.notes ? `<p class="grant-notes">${g.notes}</p>` : ""}
      <div class="grant-actions">
        <button class="btn-icon edit-grant" data-id="${g.id}">✎ Edit</button>
        <button class="btn-icon del-grant" data-id="${g.id}" style="color:var(--pink)">✕ Delete</button>
      </div>
    `;

    card.querySelector(".edit-grant")?.addEventListener("click", () => openModal(g));
    card.querySelector(".del-grant")?.addEventListener("click", async () => {
      if (confirm("Delete this grant permanently?")) {
        await deleteDoc(doc(db, "grants", g.id));
        renderGrants();
      }
    });
    container.appendChild(card);
  }
}

function openModal(grant?: any) {
  (document.getElementById("edit-grant-id") as HTMLInputElement).value = grant?.id ?? "";
  (document.getElementById("g-name")     as HTMLInputElement).value     = grant?.name      ?? "";
  (document.getElementById("g-agency")   as HTMLInputElement).value     = grant?.agency    ?? "";
  (document.getElementById("g-amount")   as HTMLInputElement).value     = grant?.amount    ?? "";
  (document.getElementById("g-status")   as HTMLSelectElement).value    = grant?.status    ?? "planning";
  (document.getElementById("g-deadline") as HTMLInputElement).value     = grant?.deadline  ?? "";
  (document.getElementById("g-url")      as HTMLInputElement).value     = grant?.url       ?? "";
  (document.getElementById("g-notes")    as HTMLTextAreaElement).value  = grant?.notes     ?? "";
  document.getElementById("modal-title")!.textContent = grant ? "EDIT GRANT" : "ADD GRANT";
  document.getElementById("grant-modal")!.style.display = "flex";
}

document.getElementById("add-grant-btn")?.addEventListener("click",  () => openModal());
document.getElementById("close-modal")?.addEventListener("click",    () => {
  document.getElementById("grant-modal")!.style.display = "none";
});

document.getElementById("save-grant-btn")?.addEventListener("click", async () => {
  const id   = (document.getElementById("edit-grant-id") as HTMLInputElement).value;
  const data = {
    name:      (document.getElementById("g-name")     as HTMLInputElement).value.trim(),
    agency:    (document.getElementById("g-agency")   as HTMLInputElement).value.trim(),
    amount:    (document.getElementById("g-amount")   as HTMLInputElement).value.trim(),
    status:    (document.getElementById("g-status")   as HTMLSelectElement).value,
    deadline:  (document.getElementById("g-deadline") as HTMLInputElement).value,
    url:       (document.getElementById("g-url")      as HTMLInputElement).value.trim(),
    notes:     (document.getElementById("g-notes")    as HTMLTextAreaElement).value.trim(),
    updatedAt: serverTimestamp(),
  };
  if (!data.name) return;

  if (id) {
    await updateDoc(doc(db, "grants", id), data);
  } else {
    await addDoc(collection(db, "grants"), { ...data, createdAt: serverTimestamp() });
  }

  document.getElementById("grant-modal")!.style.display = "none";
  renderGrants();
});
</script>

<style>
.grant-card { margin-bottom:1rem; }
.grant-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:.625rem; flex-wrap:wrap; }
.grant-name   { font-size:.9rem; font-weight:600; margin-bottom:2px; }
.grant-agency { font-size:.72rem; color:rgba(208,228,240,.45); font-family:var(--font-mono); }
.grant-amount { font-family:var(--font-mono); font-size:.72rem; color:var(--green-glow); border:.5px solid rgba(45,212,191,.25); border-radius:3px; padding:2px 7px; }
.grant-meta   { display:flex; gap:1rem; align-items:center; font-size:.72rem; color:rgba(208,228,240,.45); margin-bottom:.5rem; flex-wrap:wrap; }
.grant-notes  { font-size:.78rem; color:rgba(208,228,240,.5); line-height:1.65; margin-top:.5rem; }
.grant-actions { display:flex; gap:.5rem; margin-top:.875rem; }
.deadline-past { color:#fbbf24; }
.pub-link { font-family:var(--font-mono); font-size:.65rem; color:var(--cyan); text-decoration:none; border:.5px solid rgba(36,180,255,.2); border-radius:3px; padding:1px 6px; }
.pub-link:hover { background:rgba(36,180,255,.1); }
/* grants uses padding-based btn-icon (inline label+icon), not the global square icon button */
.btn-icon { border:.5px solid rgba(36,180,255,.2); border-radius:var(--r-sm); padding:.3rem .75rem; cursor:pointer; color:var(--cyan); font-size:.72rem; font-family:var(--font-mono); background:none; }
.btn-icon:hover { background:rgba(36,180,255,.1); }
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:.875rem; }
</style>

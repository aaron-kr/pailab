---
/**
 * src/pages/admin/tracker.astro
 * ------------------------------------------------------------------
 * Live research tracker backed by Firestore.
 * Add, edit, delete, and reorder your research ideas from any browser.
 * Only accessible by admin.
 * ------------------------------------------------------------------
 */
import ProtectedLayout from "../../layouts/ProtectedLayout.astro";
---

<ProtectedLayout role="admin" title="Research Tracker">
<style>
  .tracker-wrap { padding: 1.5rem 1rem; max-width: 1200px; margin: 0 auto; }

  .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem; }
  .top-bar h1 { margin:0; font-size:1.4rem; }

  .btn { padding:0.5rem 1rem; border-radius:6px; border:1px solid var(--border); background:transparent; color:var(--fg); cursor:pointer; font-size:0.875rem; }
  .btn-primary { background:var(--accent); color:#fff; border-color:var(--accent); }
  .btn-danger  { color:var(--danger,#e74c3c); border-color:var(--danger,#e74c3c); }
  .btn:hover   { opacity: 0.85; }

  /* Filter bar */
  .filter-bar { display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem; }
  .filter-bar input, .filter-bar select {
    padding:0.4rem 0.75rem; border:1px solid var(--border); border-radius:6px;
    background:var(--surface); color:var(--fg); font-size:0.85rem;
  }
  .filter-bar input { flex:1; min-width:180px; }

  /* Table */
  .tbl-wrap { overflow-x: auto; }
  table { width:100%; border-collapse:collapse; font-size:0.85rem; }
  th { text-align:left; padding:0.6rem 0.75rem; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--fg-muted); border-bottom:2px solid var(--border); white-space:nowrap; }
  td { padding:0.65rem 0.75rem; border-bottom:1px solid var(--border); vertical-align:top; }
  tr:hover td { background:var(--surface); }

  .status-select { background:none; border:none; cursor:pointer; font-size:1rem; padding:0; }

  .area-badge {
    display:inline-block; font-size:0.7rem; padding:2px 7px;
    border-radius:20px; background:var(--accent-bg); color:var(--accent-text);
    white-space:nowrap;
  }
  .target-cell { color:var(--fg-muted); font-size:0.8rem; }

  .pai-dot {
    display:inline-block; width:8px; height:8px;
    border-radius:50%; background:var(--accent); margin-right:4px;
  }

  .note-cell { max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:var(--fg-muted); }

  /* Modal */
  .modal-backdrop {
    display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6);
    z-index:100; align-items:center; justify-content:center;
  }
  .modal-backdrop.open { display:flex; }
  .modal {
    background:var(--bg); border:1px solid var(--border); border-radius:12px;
    padding:1.75rem; width:min(540px, 95vw); max-height:90dvh; overflow-y:auto;
  }
  .modal h2 { margin:0 0 1.25rem; font-size:1.1rem; }
  .form-row { margin-bottom:1rem; }
  .form-row label { display:block; font-size:0.8rem; color:var(--fg-muted); margin-bottom:4px; }
  .form-row input, .form-row select, .form-row textarea {
    width:100%; padding:0.5rem 0.75rem; border:1px solid var(--border);
    border-radius:6px; background:var(--surface); color:var(--fg); font-size:0.875rem;
    box-sizing:border-box;
  }
  .form-row textarea { resize:vertical; min-height:80px; }
  .form-actions { display:flex; gap:0.5rem; justify-content:flex-end; margin-top:1.25rem; }
</style>

<div class="tracker-wrap">

  <div class="top-bar">
    <div>
      <h1>Research Tracker</h1>
      <p style="margin:0.2rem 0 0; font-size:0.8rem; color:var(--fg-muted);">
        <a href="/admin" style="color:var(--accent);">← Dashboard</a>
        &nbsp;·&nbsp; Signed in as <span data-user-email></span>
        &nbsp;·&nbsp; <button data-signout class="btn" style="padding:2px 8px; font-size:0.75rem;">Sign out</button>
      </p>
    </div>
    <button class="btn btn-primary" id="add-btn">+ Add Idea</button>
  </div>

  <!-- Filters -->
  <div class="filter-bar">
    <input type="search" id="filter-text" placeholder="Search title, notes, area…" />
    <select id="filter-status">
      <option value="">All statuses</option>
      <option>⏳</option><option>▶️</option><option>✅</option><option>⛔</option><option>💡</option>
    </select>
    <select id="filter-area">
      <option value="">All areas</option>
      <option>Physical AI</option><option>OCR</option><option>Edu</option>
      <option>CV</option><option>LLM</option><option>Big Data</option><option>Sports</option>
    </select>
    <select id="filter-pai">
      <option value="">PAI: all</option>
      <option value="yes">PAI connected</option>
      <option value="no">Not connected</option>
    </select>
  </div>

  <div id="loading-msg" style="padding:2rem; text-align:center; color:var(--fg-muted);">Loading ideas…</div>

  <div class="tbl-wrap" id="table-wrap" style="display:none;">
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Title</th>
          <th>Area</th>
          <th>Stage</th>
          <th>Target venue</th>
          <th>PAI</th>
          <th>Notes</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="ideas-tbody"></tbody>
    </table>
  </div>

  <p id="empty-msg" style="display:none; text-align:center; color:var(--fg-muted); padding:2rem;">
    No ideas match the current filters.
  </p>

</div>

<!-- Add / Edit Modal -->
<div class="modal-backdrop" id="modal">
  <div class="modal">
    <h2 id="modal-title">Add Research Idea</h2>
    <form id="idea-form">
      <input type="hidden" id="f-id" />

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        <div class="form-row" style="grid-column:1/-1;">
          <label>Title *</label>
          <input id="f-title" required placeholder="Short working title" />
        </div>
        <div class="form-row">
          <label>Area</label>
          <select id="f-area">
            <option>Physical AI</option><option>OCR</option><option>Edu</option>
            <option>CV</option><option>LLM</option><option>Big Data</option>
            <option>Sports</option><option>Other</option>
          </select>
        </div>
        <div class="form-row">
          <label>Status</label>
          <select id="f-status">
            <option>💡</option><option>⏳</option><option>▶️</option>
            <option>✅</option><option>⛔</option>
          </select>
        </div>
        <div class="form-row">
          <label>Current stage</label>
          <input id="f-stage" placeholder="e.g. Data collection, Writing" />
        </div>
        <div class="form-row">
          <label>Target venue</label>
          <input id="f-target" placeholder="e.g. KIICE Spring, JPEE, Scopus" />
        </div>
        <div class="form-row" style="grid-column:1/-1;">
          <label>Physical AI connection</label>
          <textarea id="f-pailink" placeholder="How does this connect to the PAI Lab?"></textarea>
        </div>
        <div class="form-row" style="grid-column:1/-1;">
          <label>Private notes</label>
          <textarea id="f-notes" placeholder="Ideas, links, co-author notes…"></textarea>
        </div>
        <div class="form-row">
          <label>GitHub URL</label>
          <input id="f-github" type="url" placeholder="https://github.com/…" />
        </div>
        <div class="form-row">
          <label>Display order</label>
          <input id="f-order" type="number" value="99" min="0" />
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn" id="modal-cancel">Cancel</button>
        <button type="button" class="btn btn-danger" id="modal-delete" style="display:none;">Delete</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<script type="module">
  import { getAllIdeas, addIdea, updateIdea, deleteIdea } from "../../lib/tracker.ts";

  let allIdeas = [];

  // ── Load ──────────────────────────────────────────────────────────
  async function loadIdeas() {
    allIdeas = await getAllIdeas();
    renderTable(allIdeas);
    document.getElementById("loading-msg").style.display = "none";
    document.getElementById("table-wrap").style.display = "block";
  }

  // ── Render ────────────────────────────────────────────────────────
  function renderTable(ideas) {
    const tbody = document.getElementById("ideas-tbody");
    document.getElementById("empty-msg").style.display = ideas.length === 0 ? "block" : "none";
    document.getElementById("table-wrap").style.display = ideas.length === 0 ? "none" : "block";

    tbody.innerHTML = ideas.map(idea => `
      <tr data-id="${idea.id}">
        <td>
          <select class="status-select" data-field="status" data-id="${idea.id}">
            ${["💡","⏳","▶️","✅","⛔"].map(s => `<option ${s===idea.status?"selected":""}>${s}</option>`).join("")}
          </select>
        </td>
        <td>
          <strong>${idea.title}</strong>
          ${idea.githubUrl ? `<br><a href="${idea.githubUrl}" target="_blank" style="font-size:0.75rem; color:var(--accent);">GitHub ↗</a>` : ""}
        </td>
        <td><span class="area-badge">${idea.area}</span></td>
        <td style="color:var(--fg-muted); font-size:0.8rem;">${idea.stage || "—"}</td>
        <td class="target-cell">${idea.target || "—"}</td>
        <td>${idea.paiLink?.trim() ? `<span class="pai-dot" title="${idea.paiLink}"></span>Yes` : `<span style="color:var(--fg-muted); font-size:0.8rem;">—</span>`}</td>
        <td class="note-cell" title="${idea.notes || ""}">${idea.notes || "—"}</td>
        <td><button class="btn edit-btn" data-id="${idea.id}" style="padding:3px 10px; font-size:0.75rem;">Edit</button></td>
      </tr>
    `).join("");

    // Inline status change
    tbody.querySelectorAll(".status-select").forEach(sel => {
      sel.addEventListener("change", async (e) => {
        await updateIdea(e.target.dataset.id, { status: e.target.value });
      });
    });

    // Edit buttons
    tbody.querySelectorAll(".edit-btn").forEach(btn => {
      btn.addEventListener("click", () => openModal(btn.dataset.id));
    });
  }

  // ── Filters ───────────────────────────────────────────────────────
  function applyFilters() {
    const text   = document.getElementById("filter-text").value.toLowerCase();
    const status = document.getElementById("filter-status").value;
    const area   = document.getElementById("filter-area").value;
    const pai    = document.getElementById("filter-pai").value;

    const filtered = allIdeas.filter(i => {
      if (text && !`${i.title} ${i.notes} ${i.area}`.toLowerCase().includes(text)) return false;
      if (status && i.status !== status) return false;
      if (area && i.area !== area) return false;
      if (pai === "yes" && !i.paiLink?.trim()) return false;
      if (pai === "no" && i.paiLink?.trim()) return false;
      return true;
    });

    renderTable(filtered);
  }

  ["filter-text","filter-status","filter-area","filter-pai"].forEach(id => {
    document.getElementById(id).addEventListener("input", applyFilters);
    document.getElementById(id).addEventListener("change", applyFilters);
  });

  // ── Modal ─────────────────────────────────────────────────────────
  function openModal(id = null) {
    const modal = document.getElementById("modal");
    const delBtn = document.getElementById("modal-delete");
    document.getElementById("modal-title").textContent = id ? "Edit Idea" : "Add Idea";
    delBtn.style.display = id ? "inline-block" : "none";

    if (id) {
      const idea = allIdeas.find(i => i.id === id);
      document.getElementById("f-id").value      = id;
      document.getElementById("f-title").value   = idea.title;
      document.getElementById("f-area").value    = idea.area;
      document.getElementById("f-status").value  = idea.status;
      document.getElementById("f-stage").value   = idea.stage || "";
      document.getElementById("f-target").value  = idea.target || "";
      document.getElementById("f-pailink").value = idea.paiLink || "";
      document.getElementById("f-notes").value   = idea.notes || "";
      document.getElementById("f-github").value  = idea.githubUrl || "";
      document.getElementById("f-order").value   = idea.order ?? 99;
    } else {
      document.getElementById("idea-form").reset();
      document.getElementById("f-id").value = "";
    }

    modal.classList.add("open");
  }

  document.getElementById("add-btn").addEventListener("click", () => openModal());
  document.getElementById("modal-cancel").addEventListener("click", () => {
    document.getElementById("modal").classList.remove("open");
  });

  document.getElementById("modal-delete").addEventListener("click", async () => {
    const id = document.getElementById("f-id").value;
    if (!id) return;
    if (!confirm("Delete this idea? This cannot be undone.")) return;
    await deleteIdea(id);
    document.getElementById("modal").classList.remove("open");
    await loadIdeas();
  });

  document.getElementById("idea-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = document.getElementById("f-id").value;
    const data = {
      title:    document.getElementById("f-title").value.trim(),
      area:     document.getElementById("f-area").value,
      status:   document.getElementById("f-status").value,
      stage:    document.getElementById("f-stage").value.trim(),
      target:   document.getElementById("f-target").value.trim(),
      paiLink:  document.getElementById("f-pailink").value.trim(),
      notes:    document.getElementById("f-notes").value.trim(),
      githubUrl:document.getElementById("f-github").value.trim(),
      order:    parseInt(document.getElementById("f-order").value) || 99,
    };

    if (id) {
      await updateIdea(id, data);
    } else {
      await addIdea(data);
    }

    document.getElementById("modal").classList.remove("open");
    await loadIdeas();
  });

  // ── Init ──────────────────────────────────────────────────────────
  await loadIdeas();
</script>
</ProtectedLayout>

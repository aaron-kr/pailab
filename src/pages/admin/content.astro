---
// src/pages/admin/content.astro
import ProtectedLayout from "@/layouts/ProtectedLayout.astro";
---

<ProtectedLayout
  title="Content"
  description="Manage public site content and Firestore data."
  area="admin"
  requireAdmin={true}
>

  <div class="content-grid">

    <!-- Research tracker link -->
    <a href="/admin/tracker" class="app-card content-shortcut">
      <span class="shortcut-icon">⊞</span>
      <div>
        <p class="app-card-title">RESEARCH TRACKER</p>
        <p class="shortcut-desc">Add, edit, and update research ideas and paper status.</p>
      </div>
      <span class="shortcut-arrow">→</span>
    </a>

    <!-- Projects manager -->
    <div class="app-card">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <p class="app-card-title">LAB PROJECTS</p>
        <button class="btn-small" id="add-project-btn">+ New project</button>
      </div>
      <div id="projects-admin-list">
        <div class="loading-msg">Loading…</div>
      </div>
    </div>

    <!-- Students link -->
    <a href="/admin/students" class="app-card content-shortcut">
      <span class="shortcut-icon">◉</span>
      <div>
        <p class="app-card-title">STUDENT PROFILES</p>
        <p class="shortcut-desc">View and edit member profiles, roles, and assignments.</p>
      </div>
      <span class="shortcut-arrow">→</span>
    </a>

    <!-- Settings link -->
    <a href="/admin/settings" class="app-card content-shortcut">
      <span class="shortcut-icon">⚙</span>
      <div>
        <p class="app-card-title">CHECKLIST & TEMPLATES</p>
        <p class="shortcut-desc">Configure the member onboarding checklist and paper template links.</p>
      </div>
      <span class="shortcut-arrow">→</span>
    </a>

  </div>

  <!-- Add/Edit Project Modal -->
  <div class="modal-overlay" id="project-modal" style="display:none">
    <div class="modal app-card">
      <p class="app-card-title">NEW PROJECT</p>
      <input type="hidden" id="edit-project-id" />
      <div class="form-row">
        <div class="form-field">
          <label class="form-label">Title</label>
          <input class="form-input" id="proj-title" type="text" placeholder="Project title" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label">Description</label>
          <textarea class="form-input" id="proj-desc" rows="3" placeholder="Brief description…"></textarea>
        </div>
      </div>
      <div class="form-row form-row--2">
        <div class="form-field">
          <label class="form-label">Status</label>
          <select class="form-input" id="proj-status">
            <option value="active">Active</option>
            <option value="writing">Writing</option>
            <option value="submitted">Submitted</option>
            <option value="published">Published</option>
            <option value="paused">Paused</option>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label">Tags (comma-separated)</label>
          <input class="form-input" id="proj-tags" type="text" placeholder="ROS 2, Computer Vision" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label">GitHub URL (optional)</label>
          <input class="form-input" id="proj-github" type="url" placeholder="https://github.com/…" />
        </div>
      </div>
      <div style="display:flex; gap:.75rem; justify-content:flex-end; margin-top:1rem;">
        <button class="btn-ghost" id="close-project-modal">Cancel</button>
        <button class="btn-primary" id="save-project-btn">Save project</button>
      </div>
    </div>
  </div>

</ProtectedLayout>

<script>
import { getFirestore, collection, getDocs, doc, addDoc, setDoc, deleteDoc, serverTimestamp, query, orderBy } from "firebase/firestore";
import { app } from "@/lib/firebase";

const db = getFirestore(app);

async function loadProjects() {
  const container = document.getElementById("projects-admin-list")!;
  const snap = await getDocs(query(collection(db, "projects"), orderBy("created_at", "desc")));

  if (snap.empty) {
    container.innerHTML = `<p class="loading-msg">No projects yet.</p>`;
    return;
  }

  container.innerHTML = "";
  for (const d of snap.docs) {
    const p = d.data();
    const row = document.createElement("div");
    row.className = "settings-row";
    row.innerHTML = `
      <div>
        <p style="font-size:.82rem; font-weight:500;">${p.title ?? "Untitled"}</p>
        <p style="font-size:.68rem; color:rgba(208,228,240,.4); font-family:var(--font-mono);">${p.status ?? "—"}</p>
      </div>
      <div style="display:flex; gap:.5rem;">
        <button class="btn-icon del-proj" data-id="${d.id}" style="color:var(--pink)">✕</button>
      </div>
    `;
    row.querySelector(".del-proj")?.addEventListener("click", async (e) => {
      if (confirm("Delete this project?")) {
        await deleteDoc(doc(db, "projects", (e.currentTarget as HTMLElement).dataset.id!));
        loadProjects();
      }
    });
    container.appendChild(row);
  }
}

document.getElementById("add-project-btn")?.addEventListener("click", () => {
  document.getElementById("project-modal")!.style.display = "flex";
});
document.getElementById("close-project-modal")?.addEventListener("click", () => {
  document.getElementById("project-modal")!.style.display = "none";
});

document.getElementById("save-project-btn")?.addEventListener("click", async () => {
  const title  = (document.getElementById("proj-title")  as HTMLInputElement).value.trim();
  const desc   = (document.getElementById("proj-desc")   as HTMLTextAreaElement).value.trim();
  const status = (document.getElementById("proj-status") as HTMLSelectElement).value;
  const tags   = (document.getElementById("proj-tags")   as HTMLInputElement).value
    .split(",").map(s => s.trim()).filter(Boolean);
  const github = (document.getElementById("proj-github") as HTMLInputElement).value.trim() || null;
  if (!title) return;

  await addDoc(collection(db, "projects"), {
    title, description: desc, status, tags, github,
    members: [], lead_uid: null,
    created_at: serverTimestamp(), updated_at: serverTimestamp(),
  });
  document.getElementById("project-modal")!.style.display = "none";
  loadProjects();
});

loadProjects();
</script>

<style>
.content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.content-shortcut {
  display: flex; align-items: center; gap: 1rem;
  text-decoration: none; transition: border-color .15s;
  cursor: pointer;
}
.content-shortcut:hover { border-color: rgba(36,180,255,.4); text-decoration: none; }
.shortcut-icon { font-size: 1.5rem; flex-shrink: 0; color: var(--cyan); opacity: .6; }
.shortcut-desc { font-size: .75rem; color: rgba(208,228,240,.45); margin-top: 3px; }
.shortcut-arrow { color: var(--cyan); opacity: .4; font-size: 1.1rem; margin-left: auto; }
.content-shortcut:hover .shortcut-arrow { opacity: 1; }
.settings-row { display: flex; align-items: center; justify-content: space-between; padding: .625rem 0; border-bottom: .5px solid rgba(36,180,255,.08); }
.settings-row:last-child { border-bottom: none; }
.form-row { margin-bottom: .875rem; }
.form-row--2 { display: grid; grid-template-columns: 1fr 1fr; gap: .875rem; }
@media (max-width: 720px) { .content-grid { grid-template-columns: 1fr; } }
</style>

---
// src/pages/ko/notes/[...slug].astro
// Serves ALL notes at /ko/notes/[year]/[slug].
// Notes with a <!-- ko --> bilingual marker show Korean content (via CSS lang-block).
// Notes without Korean content show English text + an inline "not translated" banner.
import PostLayout from "@/layouts/PostLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const notes = (await getCollection("notes"))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  return notes.map((note, index) => ({
    params: { slug: note.slug },
    props: {
      note,
      prevPost: index < notes.length - 1
        ? { title: notes[index + 1].data.title_ko ?? notes[index + 1].data.title, slug: notes[index + 1].slug }
        : undefined,
      nextPost: index > 0
        ? { title: notes[index - 1].data.title_ko ?? notes[index - 1].data.title, slug: notes[index - 1].slug }
        : undefined,
    },
  }));
}

interface Props {
  note: CollectionEntry<"notes">;
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
}

const { note, prevPost, nextPost } = Astro.props;
const { Content } = await note.render();

const {
  title, title_ko, pubDate, tags, naver_url, lang: noteLang,
  summary, featuredImage, headerBgImage,
} = note.data;

const lang = "ko" as const;

// A note has Korean content if it uses the bilingual marker or has an external Naver URL.
const hasKoTranslation = noteLang === "ko" || noteLang === "both" || note.body.includes("<!-- ko -->");
---

<PostLayout
  title={title_ko ?? title}
  title_ko={title}
  description={summary}
  pubDate={pubDate}
  lang={lang}
  tags={tags}
  naverUrl={noteLang === "both" ? naver_url : undefined}
  prevPost={prevPost}
  nextPost={nextPost}
  featuredImage={featuredImage}
  headerBgImage={headerBgImage}
  noKoTranslation={!hasKoTranslation}
>
  <Content />
</PostLayout>

---
// src/pages/ko/notes/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import NoteRow from "@/components/NoteRow.astro";
import { getCollection } from "astro:content";
import { t } from "@/i18n/translations";

const lang = "ko" as const;
const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout lang={lang} title="노트 · PAI LAB"
  description="피지컬 AI 연구소의 연구 업데이트, 튜토리얼, 현장 노트.">

  <PageHeader
    title="노트"
    eyebrow="05 · 노트"
    description="연구 업데이트, 튜토리얼, 현장 노트 — 한국어 및 영어."
  />

  <div class="container page-content">
    <div class="row-list">
      {notes.map((note) => <NoteRow note={note} lang={lang} />)}
    </div>
  </div>
</BaseLayout>

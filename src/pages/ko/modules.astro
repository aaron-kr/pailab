---
// src/pages/ko/modules.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "ko" as const;
const modules = (await getCollection("modules")).sort((a,b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title="코스 플러그인 모듈 · PAI LAB"
  description="대학 강좌에 바로 적용할 수 있는 독립형 피지컬 AI 모듈.">
  <PageHeader title="플러그인 모듈" eyebrow="04 · 모듈"
    description="AI 중심이 아닌 과목에 바로 적용할 수 있는 독립형 피지컬 AI 모듈 — 1~3주 분량." />

  <div class="container page-content">
    <div class="module-grid">
      {modules.map(mod => (
        <a href={`/ko/modules/${mod.slug}`} class="module-card card" data-private={mod.data.private ? "true" : undefined}>
          <div class="module-bar"></div>
          <div class="module-course-tag">{mod.data.course_tag.toUpperCase()}</div>
          <h3 class="module-title">{mod.data.title_ko ?? mod.data.title}</h3>
          {mod.data.title_ko && <p class="module-en">{mod.data.title}</p>}
          <p class="module-desc">{mod.data.description_ko ?? mod.data.description}</p>
          <div class="module-footer">
            <span class="tag">{mod.data.course_tag}</span>
            <span class="tag">{mod.data.duration}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.module-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:1.25rem; }
.module-card {
  position:relative; overflow:hidden; padding:1.5rem;
  display:flex; flex-direction:column; text-decoration:none;
  transition: border-color .2s, transform .2s;
}
.module-card:hover { border-color:var(--border-2); transform:translateY(-3px); text-decoration:none; }
.module-bar {
  position:absolute; top:0; left:0; right:0; height:2.5px;
  background:linear-gradient(90deg, var(--blue), var(--cyan));
  transform:scaleX(0); transform-origin:left;
  transition:transform .32s cubic-bezier(.4,0,.2,1);
}
.module-card:hover .module-bar { transform:scaleX(1); }
.module-course-tag { font-family:var(--font-mono); font-size:.6rem; color:var(--blue); letter-spacing:.1em; margin-bottom:.625rem; }
.module-title { font-size:.9rem; font-weight:600; margin-bottom:.25rem; line-height:1.3; }
.module-en    { font-size:.72rem; color:var(--text-3); margin-bottom:.625rem; font-family:var(--font-mono); }
.module-desc  { font-size:.78rem; color:var(--text-2); line-height:1.65; flex:1; margin-bottom:1rem; }
.module-footer { margin-top:auto; display:flex; gap:6px; flex-wrap:wrap; }
</style>

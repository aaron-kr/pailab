---
// src/pages/ko/modules.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "ko" as const;
const modules = (await getCollection("modules")).sort((a,b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title="코스 플러그인 모듈 · PAI LAB"
  description="대학 강좌에 바로 적용할 수 있는 독립형 피지컬 AI 모듈.">
  <PageHeader title="플러그인 모듈" eyebrow="04 · 모듈"
    description="AI 중심이 아닌 과목에 바로 적용할 수 있는 독립형 피지컬 AI 모듈 — 1~3주 분량." />

  <div class="modules-list container page-content">
    <div class="module-grid">
      {modules.map(mod => (
        <a href={`/ko/modules/${mod.slug}`} class="module-card card" data-private={mod.data.private ? "true" : undefined}>
          <div class="module-bar"></div>
          <div class="module-course-tag">{mod.data.course_tag.toUpperCase()}</div>
          <h3 class="module-title">{mod.data.title_ko ?? mod.data.title}</h3>
          {mod.data.title_ko && <p class="module-en">{mod.data.title}</p>}
          <p class="module-desc">{mod.data.description_ko ?? mod.data.description}</p>
          <div class="module-footer">
            <span class="tag">{mod.data.course_tag}</span>
            <span class="tag">{mod.data.duration}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>


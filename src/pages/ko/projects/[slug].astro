---
// src/pages/ko/projects/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(project => ({ params: { slug: project.slug }, props: { project } }));
}

interface Props { project: CollectionEntry<"projects">; }
const { project } = Astro.props;
const { Content } = await project.render();
const { title, title_ko, year, status, tags, github, thumbnailUrl, private: isPrivate } = project.data;
const lang = "ko" as const;

const displayTitle = title_ko ?? title;

const statusColors: Record<string, string> = {
  active:    "var(--green-glow)",
  published: "var(--cyan)",
  planned:   "var(--blue)",
  archived:  "rgba(208,228,240,.3)",
};
const statusLabels: Record<string, string> = {
  active:    "진행 중",
  published: "게시됨",
  planned:   "예정",
  archived:  "보관됨",
};
---

<BaseLayout lang={lang} title={`${displayTitle} · PAI LAB`} privatePage={isPrivate}>
  <PageHeader title={displayTitle} eyebrow={`${year} · ${statusLabels[status]?.toUpperCase() ?? status.toUpperCase()}`}
    bgImage={thumbnailUrl} size="sm" />

  <div class="container page-content">
    <div class="project-layout">

      <!-- Main content -->
      <article class="prose">
        {title_ko && <p style="font-family:var(--font-mono); font-size:.72rem; color:var(--text-3); margin-bottom:1.5rem;">{title}</p>}
        <Content />
      </article>

      <!-- Sidebar meta -->
      <aside class="project-meta">
        <div class="meta-card">
          <p class="meta-label">상태</p>
          <p class="meta-value" style={`color:${statusColors[status] ?? "var(--text)"}`}>
            ● {statusLabels[status] ?? status}
          </p>
        </div>
        <div class="meta-card">
          <p class="meta-label">연도</p>
          <p class="meta-value">{year}</p>
        </div>
        {tags.length > 0 && (
          <div class="meta-card">
            <p class="meta-label">태그</p>
            <div style="display:flex; flex-wrap:wrap; gap:5px; margin-top:.375rem;">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
        )}
        {github && (
          <a href={github} target="_blank" rel="noopener" class="meta-github">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub →
          </a>
        )}
        <a href="/ko/projects" class="back-link">← 전체 프로젝트</a>
      </aside>

    </div>
  </div>
</BaseLayout>


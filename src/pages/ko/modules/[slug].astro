---
// src/pages/ko/modules/[slug].astro
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

export async function getStaticPaths() {
  const mods = await getCollection("modules");
  return mods.map((mod) => ({
    params: { slug: mod.slug },
    props: { mod },
  }));
}

interface Props {
  mod: CollectionEntry<"modules">;
}

const { mod } = Astro.props;
const lang = "ko" as const;
const { Content } = await mod.render();

const title = mod.data.title_ko ?? mod.data.title;
const desc  = mod.data.description_ko ?? mod.data.description;
---

<BaseLayout
  title={`${title} — PAI Lab`}
  description={desc}
  lang={lang}
  privatePage={mod.data.private}
>
  <PageHeader
    title={title}
    eyebrow={`모듈 · ${mod.data.course_tag.toUpperCase()}`}
    description={desc}
    size="md"
  />

  <main class="page-content">
    <div class="container">
      <div class="module-detail-grid">

        <!-- Sidebar meta -->
        <aside class="module-meta-sidebar">
          <div class="module-meta-card">
            <div class="meta-row">
              <span class="meta-label">과목</span>
              <span class="meta-value">{mod.data.course_tag.toUpperCase()}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">기간</span>
              <span class="meta-value">{mod.data.duration}</span>
            </div>
          </div>

          <a href="/ko/modules" class="btn-slide btn-slide-blue" style="display:inline-flex;margin-top:1.25rem;font-size:.75rem">
            ← 전체 모듈
          </a>
        </aside>

        <!-- Main content -->
        <article class="prose module-body">
          {mod.data.description_ko && (
            <p class="ko-description">{mod.data.description_ko}</p>
          )}
          <Content />
        </article>

      </div>
    </div>
  </main>
</BaseLayout>


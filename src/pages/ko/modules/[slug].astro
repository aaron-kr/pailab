---
// src/pages/ko/modules/[slug].astro
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

export async function getStaticPaths() {
  const mods = await getCollection("modules");
  return mods.map((mod) => ({
    params: { slug: mod.slug },
    props: { mod },
  }));
}

interface Props {
  mod: CollectionEntry<"modules">;
}

const { mod } = Astro.props;
const lang = "ko" as const;
const { Content } = await mod.render();

const title = mod.data.title_ko ?? mod.data.title;
const desc  = mod.data.description_ko ?? mod.data.description;
---

<BaseLayout
  title={`${title} — PAI Lab`}
  description={desc}
  lang={lang}
  privatePage={mod.data.private}
>
  <PageHeader
    title={title}
    eyebrow={`모듈 · ${mod.data.course_tag.toUpperCase()}`}
    description={desc}
    size="md"
  />

  <main class="page-content">
    <div class="container">
      <div class="module-detail-grid">

        <!-- Sidebar meta -->
        <aside class="module-meta-sidebar">
          <div class="module-meta-card">
            <div class="meta-row">
              <span class="meta-label">과목</span>
              <span class="meta-value">{mod.data.course_tag.toUpperCase()}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">기간</span>
              <span class="meta-value">{mod.data.duration}</span>
            </div>
          </div>

          <a href="/ko/modules" class="btn-slide btn-slide-blue" style="display:inline-flex;margin-top:1.25rem;font-size:.75rem">
            ← 전체 모듈
          </a>
        </aside>

        <!-- Main content -->
        <article class="prose module-body">
          {mod.data.description_ko && (
            <p class="ko-description">{mod.data.description_ko}</p>
          )}
          <Content />
        </article>

      </div>
    </div>
  </main>
</BaseLayout>

<style>
.module-detail-grid {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 3rem;
  align-items: start;
}
.module-meta-sidebar {
  position: sticky;
  top: calc(var(--nav-h) + 1.5rem);
}
.module-meta-card {
  background: var(--bg-surface);
  border: .5px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: .75rem;
}
.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .5rem;
  padding-bottom: .75rem;
  border-bottom: .5px solid var(--border);
}
.meta-row:last-child { border-bottom: none; padding-bottom: 0; }
.meta-label {
  font-family: var(--font-mono);
  font-size: .58rem;
  color: var(--text-3);
  letter-spacing: .06em;
}
.meta-value {
  font-family: var(--font-mono);
  font-size: .72rem;
  color: var(--cyan);
}
.ko-description {
  font-size: .88rem;
  color: var(--text-2);
  font-style: italic;
  border-left: 2px solid var(--blue);
  padding-left: 1rem;
  margin-bottom: 1.75rem;
}
.module-body { max-width: 680px; }
@media (max-width: 768px) {
  .module-detail-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  .module-meta-sidebar { position: static; }
}
</style>

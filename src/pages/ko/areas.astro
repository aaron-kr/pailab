---
// src/pages/ko/areas.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "ko" as const;
const areas = (await getCollection("areas")).sort((a,b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title="연구 분야 · PAI LAB"
  description="피지컬 AI 연구소의 연구 분야.">
  <PageHeader title="연구 분야" eyebrow="00 · 분야"
    description="피지컬 AI의 최전선에서 기계 지능이 실제 세계를 만나는 여덟 가지 상호 연결된 영역." />

  <div class="container page-content">
    <div class="areas-grid">
      {areas.map(area => (
        <a href={`/notes/category/${area.slug}`} class="area-card card">
          <div class="area-bar" style={`--bar-color: ${area.data.color ?? "var(--cyan)"}`}></div>
          <span class="area-icon">{area.data.icon ?? "◉"}</span>
          <h2 class="area-name">{area.data.title_ko ?? area.data.title}</h2>
          {area.data.title_ko && <p class="area-name-ko">{area.data.title}</p>}
          <p class="area-desc">{area.data.description_ko ?? area.data.description}</p>
          <span class="area-cta">노트 보기 →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.areas-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;}
.area-card{position:relative;overflow:hidden;padding:1.75rem;display:flex;flex-direction:column;text-decoration:none;transition:border-color .2s,transform .2s;}
.area-card:hover{border-color:var(--border-2);transform:translateY(-4px);text-decoration:none;}
.area-bar{position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--bar-color),color-mix(in srgb,var(--bar-color) 50%,transparent));transform:scaleX(0);transform-origin:left;transition:transform .32s cubic-bezier(.4,0,.2,1);}
.area-card:hover .area-bar{transform:scaleX(1);}
.area-icon{font-size:1.8rem;margin-bottom:.875rem;}
.area-name{font-size:1rem;font-weight:600;margin-bottom:.25rem;line-height:1.3;}
.area-name-ko{font-size:.72rem;color:var(--text-3);margin-bottom:.75rem;font-family:var(--font-mono);}
.area-desc{font-size:.8rem;color:var(--text-2);line-height:1.7;flex:1;margin-bottom:1.25rem;}
.area-cta{font-family:var(--font-mono);font-size:.68rem;color:var(--cyan);margin-top:auto;}
.area-card:hover .area-cta{text-decoration:underline;}
</style>

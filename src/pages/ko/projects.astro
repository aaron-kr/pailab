---
// src/pages/ko/projects.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "ko" as const;
const projects = (await getCollection("projects")).sort((a,b) => a.data.order - b.data.order);

const statusColors: Record<string, string> = {
  active:    "var(--green-glow)", published: "var(--cyan)",
  planned:   "var(--blue)",       archived:  "rgba(208,228,240,.3)",
};
const statusLabels: Record<string, string> = {
  active:    "진행 중", published: "게시됨",
  planned:   "예정",    archived:  "보관됨",
};
---

<BaseLayout lang={lang} title="프로젝트 · PAI LAB"
  description="피지컬 AI 연구소의 진행 중인 하드웨어 및 소프트웨어 프로젝트.">
  <PageHeader title="프로젝트" eyebrow="03 · 프로젝트"
    description="제스처 제어 로보틱스부터 엣지 AI 배포 파이프라인까지 — 피지컬 AI 연구소의 하드웨어·소프트웨어 프로젝트." />

  <div class="container page-content">

    {["active","published","planned","archived"].map(status => {
      const group = projects.filter(p => p.data.status === status);
      if (group.length === 0) return null;
      return (
        <section style="margin-bottom:2.5rem;">
          <p class="group-label" style={`color:${statusColors[status]}`}>
            ● {statusLabels[status].toUpperCase()} ({group.length})
          </p>
          <div class="project-grid">
            {group.map(project => (
              <a href={`/projects/${project.slug}`} class="project-card card"
                 data-private={project.data.private ? "true" : undefined}>
                {project.data.thumbnailUrl ? (
                  <div class="project-thumb">
                    <img src={project.data.thumbnailUrl} alt={project.data.title_ko ?? project.data.title} loading="lazy" />
                  </div>
                ) : (
                  <div class="project-thumb project-thumb--placeholder">
                    <span class="project-placeholder-icon">
                      {project.data.tags[0]?.slice(0,2).toUpperCase() ?? "PAI"}
                    </span>
                    <div class="project-circuit"></div>
                  </div>
                )}
                <div class="project-body">
                  <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:.5rem; margin-bottom:.5rem;">
                    <h3 class="project-title">{project.data.title_ko ?? project.data.title}</h3>
                    <span class="status-dot" style={`background:${statusColors[status]}`}></span>
                  </div>
                  {project.data.description && (
                    <p class="project-desc">{project.data.description}</p>
                  )}
                  <div style="display:flex; gap:5px; flex-wrap:wrap; margin-top:.75rem;">
                    {project.data.tags.slice(0,4).map(tag => <span class="tag">{tag}</span>)}
                  </div>
                  <p class="project-year">{project.data.year}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
.group-label { font-family:var(--font-mono); font-size:.65rem; letter-spacing:.1em; margin-bottom:1rem; }
.project-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1.25rem; }
.project-card {
  display:flex; flex-direction:column;
  text-decoration:none; overflow:hidden;
  transition: border-color .2s, transform .2s;
  padding:0;
}
.project-card:hover { border-color:var(--border-2); transform:translateY(-4px); text-decoration:none; }
.project-thumb {
  width:100%; height:160px; overflow:hidden;
  background:var(--bg-subtle); position:relative;
}
.project-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
.project-thumb--placeholder {
  display:flex; align-items:center; justify-content:center;
  background:linear-gradient(135deg, var(--bg-deep) 0%, var(--bg-subtle) 100%);
}
.project-circuit {
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(36,255,252,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(36,255,252,.05) 1px, transparent 1px);
  background-size:22px 22px;
}
.project-placeholder-icon {
  font-family:var(--font-display); font-size:2rem; font-weight:800;
  color:rgba(45,212,191,.2); position:relative; z-index:1;
}
.project-body { padding:1.25rem; flex:1; display:flex; flex-direction:column; }
.project-title { font-size:.9rem; font-weight:600; line-height:1.3; }
.project-desc  { font-size:.78rem; color:var(--text-2); line-height:1.65; margin-top:.375rem; }
.project-year  { font-family:var(--font-mono); font-size:.65rem; color:var(--text-3); margin-top:auto; padding-top:.75rem; }
.status-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; margin-top:.3rem; }
</style>

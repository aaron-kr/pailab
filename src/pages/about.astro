---
// src/pages/about.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { t } from "@/i18n/translations";

const lang = "en" as const;
---

<BaseLayout lang={lang} title="About · PAI LAB"
  description="About the Physical AI Laboratory and Principal Investigator Aaron Snowberger.">

  <PageHeader
    title="About"
    eyebrow="06 · ABOUT"
    description="The Physical AI Laboratory — pushing the boundary between intelligent software and the physical world."
  />

  <div class="container page-content">
    <div class="about-grid">

      <!-- Profile column -->
      <div class="about-profile">
        <div class="profile-img-wrap">
          <div class="profile-placeholder">AS</div>
        </div>

        <p style="font-size:.9rem; font-weight:600; margin-bottom:2px; color:var(--text);">
          Aaron Snowberger
        </p>
        <p style="font-size:.75rem; color:var(--text-2); margin-bottom:1.25rem;">
          {t(lang, "about_pi_role")}
        </p>

        <div style="border-top:.5px solid var(--border); padding-top:1rem; display:flex; flex-direction:column; gap:6px;">
          <a href="https://aaron.kr"                           class="pi-link">aaron.kr</a>
          <a href="https://aaronsnowberger.com"                class="pi-link">aaronsnowberger.com</a>
          <a href="https://kspai.org"                          class="pi-link">kspai.org</a>
          <a href="https://aaronkr-courses.github.io/courses/" class="pi-link" style="font-family:var(--font-mono); font-size:.68rem;">courses.aaron.kr</a>
          <a href="https://blog.naver.com/aaron_kr"            class="pi-link">{t(lang, "about_naver")}</a>
        </div>
      </div>

      <!-- Bio column -->
      <div>
        <p style="font-size:.95rem; line-height:1.85; margin-bottom:1.25rem; color:var(--text);">
          {t(lang, "about_body")}
        </p>

        <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:2rem;">
          <span class="tag accent">Physical AI</span>
          <span class="tag">Embedded Systems</span>
          <span class="tag">Edge ML</span>
          <span class="tag">Robotics</span>
          <span class="tag ok">Open Research</span>
        </div>

        <div style="border-top:.5px solid var(--border); padding-top:1.5rem;">
          <p style="font-family:var(--font-mono); font-size:.68rem; color:var(--text-3); letter-spacing:.1em; margin-bottom:.875rem;">
            AFFILIATED INSTITUTIONS
          </p>
          <div style="display:flex; gap:6px; flex-wrap:wrap;">
            <span class="tag">전북대학교</span>
            <span class="tag">한국교통대</span>
            <span class="tag">한밭대학교</span>
            <span class="tag">원광대학교</span>
            <span class="tag">전주교육대</span>
            <span class="tag accent">KSPAI</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>


---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

export async function getStaticPaths() {
  const tracks = await getCollection("curriculum");
  return tracks.map((track) => ({
    params: { slug: track.slug },
    props: { track },
  }));
}

interface Props {
  track: CollectionEntry<"curriculum">;
}

const { track } = Astro.props;
const lang = "en";

const { Content } = await track.render();

const levelColors: Record<string, string> = {
  beginner:     "ok",
  intermediate: "blue",
  advanced:     "pink",
  open:         "warn",
};

const levelBadgeColor = levelColors[track.data.level] ?? "";
---

<BaseLayout
  title={`${track.data.title} — PAI Lab`}
  description={track.data.description}
  lang={lang}
  privatePage={track.data.private}
>
  <PageHeader
    title={track.data.title}
    eyebrow={`TRACK ${track.data.track}`}
    description={track.data.description}
    size="md"
  />

  <main class="page-content">
    <div class="container">
      <div class="curriculum-detail-grid">

        <!-- Sidebar meta -->
        <aside class="curriculum-meta-sidebar">
          <div class="curriculum-meta-card">
            <div class="meta-row">
              <span class="meta-label">Track</span>
              <span class="meta-value">{track.data.track}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Level</span>
              <span class={`pill ${levelBadgeColor}`}>{track.data.level}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Units</span>
              <span class="meta-value">{track.data.units}</span>
            </div>
            {track.data.bilingual && (
              <div class="meta-row">
                <span class="meta-label">Language</span>
                <span class="pill blue">EN · 한국어</span>
              </div>
            )}
          </div>

          <a href="/curriculum" class="btn-slide btn-slide-green" style="display:inline-flex;margin-top:1.25rem;font-size:.75rem">
            ← All tracks
          </a>
        </aside>

        <!-- Main content -->
        <article class="prose curriculum-body">
          {track.data.description_ko && (
            <p class="ko-description">{track.data.description_ko}</p>
          )}
          <Content />
        </article>

      </div>
    </div>
  </main>
</BaseLayout>


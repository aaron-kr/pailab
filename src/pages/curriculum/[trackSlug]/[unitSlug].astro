---
// src/pages/curriculum/[trackSlug]/[unitSlug].astro
// Individual unit/lesson page — URL: /curriculum/track-05-arduino/unit-01-intro
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

export async function getStaticPaths() {
  const allUnits = await getCollection("units");
  return allUnits.map((unit) => {
    const [trackSlug, unitSlug] = unit.slug.split("/");
    return {
      params: { trackSlug, unitSlug },
      props: { unit },
    };
  });
}

interface Props {
  unit: CollectionEntry<"units">;
}

const { unit } = Astro.props;
const lang = "en";

const { Content } = await unit.render();

// Load the parent track for breadcrumb and back link
const allTracks = await getCollection("curriculum");
const track = allTracks.find((t) => t.slug === unit.data.track);

const trackTitle = track?.data.title ?? unit.data.track;
const trackSlug  = unit.data.track;
---

<BaseLayout
  title={`${unit.data.title} — PAI Lab`}
  description={unit.data.description ?? unit.data.title}
  lang={lang}
  privatePage={unit.data.private}
>
  <PageHeader
    title={unit.data.title}
    eyebrow={`UNIT ${unit.data.unit_number}`}
    description={unit.data.description ?? ""}
    size="md"
  />

  <main class="page-content">
    <div class="container">
      <div class="unit-detail-grid">

        <!-- Sidebar meta -->
        <aside class="curriculum-meta-sidebar">
          <div class="curriculum-meta-card">
            <div class="meta-row">
              <span class="meta-label">Unit</span>
              <span class="meta-value">{unit.data.unit_number}</span>
            </div>
            {unit.data.duration && (
              <div class="meta-row">
                <span class="meta-label">Duration</span>
                <span class="meta-value">{unit.data.duration}</span>
              </div>
            )}
            <div class="meta-row">
              <span class="meta-label">Track</span>
              <span class="meta-value" style="font-size:.65rem;">{trackTitle}</span>
            </div>
          </div>

          {unit.data.objectives.length > 0 && (
            <div class="unit-objectives">
              <p class="unit-obj-label">OBJECTIVES</p>
              <ul class="unit-obj-list">
                {unit.data.objectives.map(obj => <li>{obj}</li>)}
              </ul>
            </div>
          )}

          <div style="display:flex; flex-direction:column; gap:8px; margin-top:1.25rem;">
            <a href={`/curriculum/${trackSlug}`} class="btn-slide btn-slide-green"
              style="display:inline-flex; font-size:.72rem;">
              ← Back to track
            </a>
            <a href="/curriculum" class="btn-slide"
              style="display:inline-flex; font-size:.72rem; border-color:var(--border);">
              All tracks
            </a>
          </div>
        </aside>

        <!-- Main prose content -->
        <article class="prose unit-body">
          {unit.data.description_ko && (
            <p class="ko-description">{unit.data.description_ko}</p>
          )}
          <Content />
        </article>

      </div>
    </div>
  </main>
</BaseLayout>

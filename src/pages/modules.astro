---
// src/pages/modules.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const modules = (await getCollection("modules")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout lang={lang} title="Course plug-in modules · PAI LAB"
  description="Self-contained Physical AI add-ons for any university course.">

  <PageHeader
    title="Plug-in Modules"
    eyebrow="04 · MODULES"
    description="Self-contained Physical AI add-ons for courses not primarily focused on AI — drop one in for 1–2 weeks of hands-on physical computing."
  />

  <div class="container page-content">
    <div class="card-grid">
      {modules.map((mod) => (
        <div class="card module-card">
          <div style="font-family:var(--font-mono); font-size:.68rem; color:var(--text-3); margin-bottom:.5rem;">
            MODULE · {mod.data.course_tag.toUpperCase()}
          </div>
          <h3 style="font-size:.9rem; margin-bottom:.375rem;">{mod.data.title}</h3>
          {mod.data.title_ko && (
            <p style="font-size:.75rem; color:var(--text-3); margin-bottom:.5rem;">{mod.data.title_ko}</p>
          )}
          <p style="font-size:.8rem; color:var(--text-2); margin-bottom:.875rem; line-height:1.6;">
            {mod.data.description}
          </p>
          <div style="display:flex; gap:6px; flex-wrap:wrap;">
            <span class="tag">{mod.data.course_tag}</span>
            <span class="tag">{mod.data.duration}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

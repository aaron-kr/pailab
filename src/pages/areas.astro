---
// src/pages/areas.astro
// FIX: use area.id (auto-generated by Astro from filename), NOT area.data.id
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const areas = (await getCollection("areas")).sort((a,b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title="Research Areas · PAI LAB"
  description="The eight research areas of the PAI Laboratory.">
  <PageHeader title="Research Areas" eyebrow="00 · AREAS"
    description="Our work spans eight interconnected domains at the frontier of Physical AI — where machine intelligence meets the real world." />

  <div class="container page-content">
    <div class="areas-grid">
      {areas.map(area => (
        // area.id = filename without .md (e.g. "embodied-intelligence")
        <a href={`/notes/category/${area.id}`} class="area-card card">
          <div class="area-bar" style={`--bar-color: ${area.data.color ?? "var(--cyan)"}`}></div>
          <span class="area-icon">{area.data.icon ?? "◉"}</span>
          <h2 class="area-name">{area.data.title}</h2>
          {area.data.title_ko && <p class="area-name-ko">{area.data.title_ko}</p>}
          <p class="area-desc">{area.data.description}</p>
          <span class="area-cta">View notes →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>


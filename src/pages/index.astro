---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import ResearchCard from "@/components/ResearchCard.astro";
import ProjectRow from "@/components/ProjectRow.astro";
import NoteRow from "@/components/NoteRow.astro";
import { getCollection } from "astro:content";
import { t } from "@/i18n/translations";

const lang = "en";

const research   = (await getCollection("research")).sort((a, b) => b.data.year - a.data.year);
const curriculum = (await getCollection("curriculum")).sort((a, b) => a.data.order - b.data.order);
const projects   = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const modules    = (await getCollection("modules")).sort((a, b) => a.data.order - b.data.order);
const notes      = (await getCollection("notes"))
                    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
                    .slice(0, 5);

const levelLabel: Record<string, string> = {
  beginner:     "Beginner",
  intermediate: "Intermediate",
  advanced:     "Advanced",
  open:         "Open data",
};
---

<BaseLayout lang={lang}>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <Hero lang={lang} />

  <!-- ── 01 Research ──────────────────────────────────────── -->
  <section class="section" id="research">
    <div class="section-header">
      <span class="sec-num">01</span>
      <h2>{t(lang, "sec_research")}</h2>
    </div>

    <div class="card-grid">
      {research.map((paper) => <ResearchCard paper={paper} lang={lang} />)}
    </div>

    <div style="margin-top: 1rem; text-align: right;">
      <a href="/research" style="font-size: 0.8rem; color: var(--text-2);">
        {t(lang, "view_all")} →
      </a>
    </div>
  </section>

  <!-- ── 02 Curriculum ────────────────────────────────────── -->
  <section class="section" id="curriculum">
    <div class="section-header">
      <span class="sec-num">02</span>
      <h2>{t(lang, "sec_curriculum")}</h2>
    </div>

    <div class="card-grid">
      {curriculum.map((track) => (
        <div class="card">
          <div style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-3); margin-bottom: 0.5rem;">
            TRACK {track.data.track} · {levelLabel[track.data.level].toUpperCase()}
          </div>
          <h3 style="font-size: 0.875rem; margin-bottom: 0.375rem;">{track.data.title}</h3>
          <p style="font-size: 0.78rem; color: var(--text-2); margin-bottom: 0.75rem; line-height: 1.55;">
            {track.data.description}
          </p>
          <span class="tag">{track.data.units} units</span>
          {track.data.bilingual && <span class="tag accent">EN · 한국어</span>}
        </div>
      ))}
    </div>
  </section>

  <!-- ── 03 Projects ──────────────────────────────────────── -->
  <section class="section" id="projects">
    <div class="section-header">
      <span class="sec-num">03</span>
      <h2>{t(lang, "sec_projects")}</h2>
    </div>

    <div class="row-list">
      {projects.map((project) => <ProjectRow project={project} lang={lang} />)}
    </div>
  </section>

  <!-- ── 04 Modules ───────────────────────────────────────── -->
  <section class="section" id="modules">
    <div class="section-header">
      <span class="sec-num">04</span>
      <h2>{t(lang, "sec_modules")}</h2>
    </div>
    <p style="font-size: 0.78rem; color: var(--text-2); margin: -1rem 0 1.75rem 1.75rem;">
      {t(lang, "sec_modules_sub")}
    </p>

    <div class="card-grid">
      {modules.map((mod) => (
        <div class="card">
          <div style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-3); margin-bottom: 0.5rem;">
            MODULE · {mod.data.course_tag.toUpperCase()}
          </div>
          <h3 style="font-size: 0.875rem; margin-bottom: 0.375rem;">{mod.data.title}</h3>
          <p style="font-size: 0.78rem; color: var(--text-2); margin-bottom: 0.75rem; line-height: 1.55;">
            {mod.data.description}
          </p>
          <span class="tag">{mod.data.course_tag}</span>
          <span class="tag">{mod.data.duration}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 05 Notes ─────────────────────────────────────────── -->
  <section class="section" id="notes">
    <div class="section-header">
      <span class="sec-num">05</span>
      <h2>{t(lang, "sec_notes")}</h2>
    </div>

    <div class="row-list">
      {notes.map((note) => <NoteRow note={note} lang={lang} />)}
    </div>

    <div style="margin-top: 1rem; text-align: right;">
      <a href="/notes" style="font-size: 0.8rem; color: var(--text-2);">
        {t(lang, "view_all")} →
      </a>
    </div>
  </section>

  <!-- ── 06 About ─────────────────────────────────────────── -->
  <section class="section" id="about">
    <div class="section-header">
      <span class="sec-num">06</span>
      <h2>{t(lang, "sec_about")}</h2>
    </div>

    <div class="about-grid">
      <!-- PI Card -->
      <div class="card" style="text-align: center;">
        <div class="avatar" style="margin: 0 auto 1rem;">AS</div>
        <p style="font-size: 0.9rem; font-weight: 500; margin-bottom: 2px;">Aaron Snowberger</p>
        <p style="font-size: 0.75rem; color: var(--text-2); margin-bottom: 1rem;">
          {t(lang, "about_pi_role")}
        </p>
        <div style="border-top: 0.5px solid var(--border); padding-top: 0.875rem; text-align: left; display: flex; flex-direction: column; gap: 6px;">
          <a href="https://aaron.kr"             class="pi-link">aaron.kr</a>
          <a href="https://aaronsnowberger.com"  class="pi-link">aaronsnowberger.com</a>
          <a href="https://kspai.org"            class="pi-link">kspai.org</a>
          <a href="https://aaronkr-courses.github.io/courses/"
             class="pi-link" style="font-family: var(--font-mono); font-size: 0.72rem;">
            courses.aaron.kr
          </a>
          <a href="https://blog.naver.com/aaron_kr" class="pi-link">
            {t(lang, "about_naver")}
          </a>
        </div>
      </div>

      <!-- About text -->
      <div>
        <p style="font-size: 0.9rem; line-height: 1.8; margin-bottom: 1rem;">
          {t(lang, "about_body")}
        </p>

        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.5rem;">
          <span class="tag accent">Physical AI</span>
          <span class="tag">Embedded Systems</span>
          <span class="tag">Edge ML</span>
          <span class="tag">Robotics</span>
          <span class="tag ok">Open research</span>
        </div>

        <div style="border-top: 0.5px solid var(--border); padding-top: 1.25rem;">
          <p style="font-size: 0.72rem; color: var(--text-2); margin-bottom: 0.5rem;">
            {t(lang, "about_affiliated")}
          </p>
          <div style="display: flex; gap: 6px; flex-wrap: wrap;">
            <span class="tag">전북대학교 JBNU</span>
            <span class="tag">한국교통대 UT</span>
            <span class="tag">한밭대학교 HBU</span>
            <span class="tag">원광대학교 WKU</span>
            <span class="tag">전주교육대 JNUE</span>
            <span class="tag accent">KSPAI</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.about-grid {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 2.5rem;
  align-items: start;
}

.pi-link {
  font-size: 0.78rem;
  color: var(--accent);
  text-decoration: none;
}
.pi-link:hover { text-decoration: underline; }

@media (max-width: 640px) {
  .about-grid { grid-template-columns: 1fr; }
}
</style>

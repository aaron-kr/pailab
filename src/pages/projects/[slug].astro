---
// src/pages/projects/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(project => ({ params: { slug: project.slug }, props: { project } }));
}

interface Props { project: CollectionEntry<"projects">; }
const { project } = Astro.props;
const { Content } = await project.render();
const { title, title_ko, year, status, tags, github, thumbnailUrl } = project.data;
const lang = "en" as const;

const statusColors: Record<string, string> = {
  active:    "var(--green-glow)",
  published: "var(--cyan)",
  planned:   "var(--blue)",
  archived:  "rgba(208,228,240,.3)",
};
---

<BaseLayout lang={lang} title={`${title} · PAI LAB`}>
  <PageHeader title={title} eyebrow={`${year} · ${status.toUpperCase()}`}
    bgImage={thumbnailUrl} size="sm" />

  <div class="container page-content">
    <div class="project-layout">

      <!-- Main content -->
      <article class="prose">
        {title_ko && <p style="font-family:var(--font-mono); font-size:.72rem; color:var(--text-3); margin-bottom:1.5rem;">{title_ko}</p>}
        <Content />
      </article>

      <!-- Sidebar meta -->
      <aside class="project-meta">
        <div class="meta-card">
          <p class="meta-label">STATUS</p>
          <p class="meta-value" style={`color:${statusColors[status] ?? "var(--text)"}`}>
            ● {status}
          </p>
        </div>
        <div class="meta-card">
          <p class="meta-label">YEAR</p>
          <p class="meta-value">{year}</p>
        </div>
        {tags.length > 0 && (
          <div class="meta-card">
            <p class="meta-label">TAGS</p>
            <div style="display:flex; flex-wrap:wrap; gap:5px; margin-top:.375rem;">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
        )}
        {github && (
          <a href={github} target="_blank" rel="noopener" class="meta-github">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub →
          </a>
        )}
        <a href="/projects" class="back-link">← All projects</a>
      </aside>

    </div>
  </div>
</BaseLayout>

<style>
.project-layout {
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: 3rem;
  align-items: start;
}
.project-meta { display: flex; flex-direction: column; gap: .875rem; position: sticky; top: calc(var(--nav-h) + 1.5rem); }
.meta-card { background: var(--bg-subtle); border-radius: var(--r-md); padding: .875rem 1rem; }
.meta-label { font-family: var(--font-mono); font-size: .6rem; color: var(--text-3); letter-spacing: .1em; margin-bottom: .25rem; }
.meta-value { font-size: .82rem; font-weight: 500; }
.meta-github {
  display: flex; align-items: center; gap: .5rem;
  background: var(--bg-subtle); border-radius: var(--r-md);
  padding: .75rem 1rem; font-family: var(--font-mono); font-size: .72rem;
  color: var(--cyan); text-decoration: none; border: .5px solid rgba(36,180,255,.2);
}
.meta-github:hover { background: rgba(36,180,255,.08); }
.back-link { font-family: var(--font-mono); font-size: .68rem; color: var(--text-3); text-decoration: none; }
.back-link:hover { color: var(--cyan); }
@media (max-width: 720px) { .project-layout { grid-template-columns: 1fr; } .project-meta { position: static; } }
</style>

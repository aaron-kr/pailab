---
// src/pages/research.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ResearchCard from "@/components/ResearchCard.astro";
import { getCollection } from "astro:content";

const lang = "en" as const;
const papers = (await getCollection("research")).sort(
  (a, b) => b.data.year - a.data.year
);
const featured = papers.filter((p) => p.data.featured);
const rest     = papers.filter((p) => !p.data.featured);
---

<BaseLayout lang={lang} title="Research · PAI LAB"
  description="Papers, publications, and active research in Physical AI.">

  <PageHeader
    title="Research"
    eyebrow="01 · RESEARCH"
    description="Papers, publications, and active research spanning dataset creation, physical AI, embedded ML, autonomous systems, and education."
  />

  <div class="container page-content">

    {featured.length > 0 && (
      <section style="margin-bottom:3rem;">
        <h2 class="section-sub-label">Featured</h2>
        <div class="card-grid">
          {featured.map((p) => <ResearchCard paper={p} lang={lang} />)}
        </div>
      </section>
    )}

    {rest.length > 0 && (
      <section>
        <h2 class="section-sub-label">All Publications</h2>
        <div class="card-grid">
          {rest.map((p) => <ResearchCard paper={p} lang={lang} />)}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
.section-sub-label {
  font-family: var(--font-mono);
  font-size: .68rem;
  color: var(--text-3);
  letter-spacing: .12em;
  margin-bottom: 1.25rem;
}
</style>
